{% extends "layouts.master" %}

{% block content %}

<style>
/* ===== GATEWAY ===== */
#lv-gateway {
    position:fixed;inset:0;z-index:99999;pointer-events:all;
}
.lv-gw-panel {
    position:absolute;top:0;bottom:0;width:50%;
    background:#0e0d0c;
    transition:transform 1.1s cubic-bezier(0.77,0,0.18,1);
}
.lv-gw-panel--left  { left:0; }
.lv-gw-panel--right { right:0; }
.lv-gw-center {
    position:absolute;inset:0;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    z-index:2;pointer-events:none;
}
.lv-gw-line {
    width:0;height:1px;background:#C9A84C;margin-bottom:40px;
    animation:gwLine 1.2s ease 0.3s forwards;
}
@keyframes gwLine { to { width:180px; } }
.lv-gw-logo {
    max-width:200px;max-height:90px;object-fit:contain;
    opacity:0;animation:gwFadeIn 0.9s ease 0.8s forwards;
}
.lv-gw-text {
    color:#fff;font-size:2rem;font-weight:200;
    letter-spacing:12px;text-transform:uppercase;
    opacity:0;animation:gwFadeIn 0.9s ease 0.8s forwards;
}
.lv-gw-sub {
    color:#C9A84C;font-size:10px;letter-spacing:5px;
    text-transform:uppercase;margin-top:14px;
    opacity:0;animation:gwFadeIn 0.9s ease 1.1s forwards;
}
.lv-gw-line-b {
    width:0;height:1px;background:#C9A84C;margin-top:40px;
    animation:gwLine 1.2s ease 0.3s forwards;
}
.lv-gw-enter {
    position:absolute;bottom:48px;left:50%;transform:translateX(-50%);
    color:rgba(255,255,255,0.45);font-size:10px;letter-spacing:4px;
    text-transform:uppercase;opacity:0;
    animation:gwFadeIn 0.8s ease 1.8s forwards, gwBlink 2s ease 2.6s infinite;
    border:none;background:transparent;cursor:pointer;z-index:3;
}
@keyframes gwFadeIn { to { opacity:1; } }
@keyframes gwBlink { 0%,100%{opacity:0.4;} 50%{opacity:0.95;} }
#lv-gateway.lv-open .lv-gw-panel--left  { transform:translateX(-100%); }
#lv-gateway.lv-open .lv-gw-panel--right { transform:translateX(100%); }
#lv-gateway.lv-gone { opacity:0;pointer-events:none;transition:opacity 0.4s ease 0.9s; }

/* ===== SPLASH بسيط ===== */
#lv-splash {
    position:fixed;inset:0;z-index:99999;
    display:flex;align-items:center;justify-content:center;flex-direction:column;
    pointer-events:none;
    animation:splashFade 0.7s ease 2.4s forwards;
}
#lv-splash img { max-width:220px;max-height:130px;object-fit:contain;animation:splashScale 1s ease; }
#lv-splash .splash-text { font-size:2rem;font-weight:200;letter-spacing:10px;color:#1a1a1a;animation:splashScale 1s ease; }
@keyframes splashFade { to { opacity:0;visibility:hidden; } }
@keyframes splashScale { from { opacity:0;transform:scale(0.9); } to { opacity:1;transform:scale(1); } }

/* ===== HERO ===== */
.lv-hero { position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center; }
.lv-hero__bg { position:absolute;inset:0;width:100%;height:100%;object-fit:cover; }
.lv-hero__video { position:absolute;inset:0;width:100%;height:100%;object-fit:cover; }
.lv-hero__overlay { position:absolute;inset:0; }
.lv-hero__content { position:relative;z-index:2;text-align:center;padding:0 24px; }
.lv-hero__label { color:#C9A84C;letter-spacing:5px;font-size:11px;text-transform:uppercase;margin:0 0 16px;display:block; }
.lv-hero__title { color:#fff;font-size:clamp(2rem,6vw,5rem);font-weight:200;margin:0 0 16px;line-height:1.05;letter-spacing:2px; }
.lv-hero__subtitle { color:rgba(255,255,255,0.82);font-size:1rem;margin:0 0 36px;display:block; }
.lv-hero__btn { display:inline-block;padding:14px 48px;background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.8);text-decoration:none;font-size:13px;letter-spacing:3px;text-transform:uppercase;transition:all 0.3s; }
.lv-hero__btn:hover { background:#fff;color:#1a1a1a; }
.lv-slider { position:absolute;inset:0; }
.lv-slider__item { position:absolute;inset:0;opacity:0;transition:opacity 1s ease; }
.lv-slider__item.active { opacity:1; }
.lv-slider__item img { width:100%;height:100%;object-fit:cover; }
.lv-slider__dots { position:absolute;bottom:28px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:3; }
.lv-slider__dot { width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,0.4);border:none;cursor:pointer;padding:0;transition:background 0.3s; }
.lv-slider__dot.active { background:#fff; }
.lv-hero__scroll { position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center; }
.lv-hero__scroll span { display:block;width:1px;height:52px;background:rgba(255,255,255,0.45);animation:scrollLine 1.8s ease infinite; }
@keyframes scrollLine { 0%,100%{transform:scaleY(1);opacity:1;} 50%{transform:scaleY(0.3);opacity:0.3;} }

/* ===== EDITORIAL ===== */
.lv-editorial { display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:560px; }
.lv-editorial__img { overflow:hidden; }
.lv-editorial__img img { width:100%;height:100%;object-fit:cover;transition:transform 0.7s ease;display:block; }
.lv-editorial:hover .lv-editorial__img img { transform:scale(1.03); }
.lv-editorial__body { background:#f9f7f4;display:flex;flex-direction:column;justify-content:center;padding:80px 64px; }
.lv-editorial__label { color:#C9A84C;letter-spacing:5px;font-size:11px;text-transform:uppercase;margin:0 0 20px; }
.lv-editorial__title { font-size:2.2rem;font-weight:200;color:#1a1a1a;margin:0 0 24px;line-height:1.2; }
.lv-editorial__text { color:#666;line-height:1.9;margin:0 0 40px;font-size:15px; }
.lv-editorial__btn { display:inline-block;padding:12px 36px;border:1px solid #1a1a1a;color:#1a1a1a;text-decoration:none;font-size:12px;letter-spacing:2px;text-transform:uppercase;transition:all 0.3s;width:fit-content; }
.lv-editorial__btn:hover { background:#1a1a1a;color:#fff; }

/* ===== WHATSAPP ===== */
.lv-wa { position:fixed;bottom:28px;z-index:9999;width:54px;height:54px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.4);transition:transform 0.2s; }
.lv-wa:hover { transform:scale(1.1); }
.lv-wa--left  { left:26px; }
.lv-wa--right { right:26px; }

/* ===== زر الأعلى ===== */
#lv-top-btn { position:fixed;bottom:28px;right:26px;z-index:9998;width:44px;height:44px;background:#1a1a1a;color:#fff;border:none;cursor:pointer;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:18px;box-shadow:0 4px 16px rgba(0,0,0,0.2);transition:background 0.2s; }
#lv-top-btn:hover { background:#C9A84C; }

/* ===== عناوين الأقسام ===== */
.s-block__title { padding:0 0 10px !important;border-bottom:1px solid #efefef !important;margin-bottom:36px !important; }
.s-block__title h2 { font-size:1.3rem !important;font-weight:300 !important;letter-spacing:1.5px !important;color:#1a1a1a !important; }
.s-block__display-all { font-size:11px !important;letter-spacing:2px !important;text-transform:uppercase !important;color:#1a1a1a !important;border-bottom:1px solid #1a1a1a !important;text-decoration:none !important;padding-bottom:2px !important;font-weight:400 !important; }

/* ===== RESPONSIVE ===== */
@media (max-width:1024px) {
    .lv-editorial { grid-template-columns:1fr;min-height:auto; }
    .lv-editorial__img { min-height:380px; }
    .lv-editorial__body { padding:56px 40px; }
}
@media (max-width:768px) {
    .lv-editorial__body { padding:40px 24px; }
    .lv-editorial__title { font-size:1.8rem; }
    .lv-wa { width:48px;height:48px;bottom:20px; }
    .lv-wa--left  { left:18px; }
    .lv-wa--right { right:18px; }
    #lv-top-btn { bottom:20px;right:18px; }
}
@media (max-width:480px) {
    .lv-hero__btn { padding:11px 28px;font-size:12px; }
    .lv-editorial__body { padding:32px 20px; }
    .lv-editorial__title { font-size:1.5rem; }
}
</style>

