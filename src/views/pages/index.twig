{% extends "layouts.master" %}

{% block content %}
<style>
#lv-gateway{position:fixed;inset:0;z-index:99999;pointer-events:all}
.lv-gw-panel{position:absolute;top:0;bottom:0;width:50%;background:#0e0d0c;transition:transform 1.1s cubic-bezier(0.77,0,0.18,1)}
.lv-gw-panel--left{left:0}
.lv-gw-panel--right{right:0}
.lv-gw-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:2;pointer-events:none}
.lv-gw-line,.lv-gw-line-b{height:1px;background:#C9A84C;width:0;animation:gwLine 1.2s ease 0.3s forwards}
.lv-gw-line{margin-bottom:40px}
.lv-gw-line-b{margin-top:40px}
@keyframes gwLine{to{width:180px}}
.lv-gw-logo{max-width:200px;max-height:90px;object-fit:contain;opacity:0;animation:gwFade 0.9s ease 0.8s forwards}
.lv-gw-text{color:#fff;font-size:2rem;font-weight:200;letter-spacing:12px;text-transform:uppercase;opacity:0;animation:gwFade 0.9s ease 0.8s forwards}
.lv-gw-sub{color:#C9A84C;font-size:10px;letter-spacing:5px;text-transform:uppercase;margin-top:14px;opacity:0;animation:gwFade 0.9s ease 1.1s forwards}
.lv-gw-btn{position:absolute;bottom:48px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.45);font-size:10px;letter-spacing:4px;text-transform:uppercase;opacity:0;animation:gwFade 0.8s ease 1.8s forwards;border:none;background:transparent;cursor:pointer;z-index:3;padding:10px 24px}
@keyframes gwFade{to{opacity:1}}
#lv-gateway.lv-open .lv-gw-panel--left{transform:translateX(-100%)}
#lv-gateway.lv-open .lv-gw-panel--right{transform:translateX(100%)}
#lv-gateway.lv-gone{opacity:0;pointer-events:none;transition:opacity 0.4s ease 0.9s}
.lv-hero{position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.lv-hero__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.lv-hero__video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.lv-hero__overlay{position:absolute;inset:0}
.lv-hero__content{position:relative;z-index:2;text-align:center;padding:0 24px}
.lv-hero__label{color:#C9A84C;letter-spacing:5px;font-size:11px;text-transform:uppercase;margin:0 0 16px;display:block}
.lv-hero__title{color:#fff;font-size:clamp(2rem,6vw,5rem);font-weight:200;margin:0 0 16px;line-height:1.05;letter-spacing:2px}
.lv-hero__subtitle{color:rgba(255,255,255,0.82);font-size:1rem;margin:0 0 36px;display:block}
.lv-hero__btn{display:inline-block;padding:14px 48px;background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.8);text-decoration:none;font-size:13px;letter-spacing:3px;text-transform:uppercase;transition:all 0.3s}
.lv-hero__btn:hover{background:#fff;color:#1a1a1a}
.lv-slider{position:absolute;inset:0}
.lv-slider__item{position:absolute;inset:0;opacity:0;transition:opacity 1s ease}
.lv-slider__item.active{opacity:1}
.lv-slider__item img{width:100%;height:100%;object-fit:cover}
.lv-slider__dots{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:3}
.lv-slider__dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,0.4);border:none;cursor:pointer;padding:0;transition:background 0.3s}
.lv-slider__dot.active{background:#fff}
.lv-hero__scroll{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:3}
.lv-hero__scroll span{display:block;width:1px;height:52px;background:rgba(255,255,255,0.45);animation:scrollAnim 1.8s ease infinite}
@keyframes scrollAnim{0%,100%{transform:scaleY(1);opacity:1}50%{transform:scaleY(0.3);opacity:0.3}}
.lv-editorial{display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:560px}
.lv-editorial__img{overflow:hidden}
.lv-editorial__img img{width:100%;height:100%;object-fit:cover;display:block}
.lv-editorial__body{background:#f9f7f4;display:flex;flex-direction:column;justify-content:center;padding:80px 64px}
.lv-editorial__label{color:#C9A84C;letter-spacing:5px;font-size:11px;text-transform:uppercase;margin:0 0 20px}
.lv-editorial__title{font-size:2.2rem;font-weight:200;color:#1a1a1a;margin:0 0 24px;line-height:1.2}
.lv-editorial__text{color:#666;line-height:1.9;margin:0 0 40px;font-size:15px}
.lv-editorial__btn{display:inline-block;padding:12px 36px;border:1px solid #1a1a1a;color:#1a1a1a;text-decoration:none;font-size:12px;letter-spacing:2px;text-transform:uppercase;transition:all 0.3s}
.lv-editorial__btn:hover{background:#1a1a1a;color:#fff}
.lv-wa{position:fixed;bottom:28px;z-index:9999;width:54px;height:54px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.4);transition:transform 0.2s}
.lv-wa:hover{transform:scale(1.1)}
.lv-wa--left{left:26px}
.lv-wa--right{right:26px}
#lv-top-btn{position:fixed;bottom:28px;right:26px;z-index:9998;width:44px;height:44px;background:#1a1a1a;color:#fff;border:none;cursor:pointer;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:18px;box-shadow:0 4px 16px rgba(0,0,0,0.2);transition:background 0.2s}
#lv-top-btn:hover{background:#C9A84C}
@media(max-width:1024px){.lv-editorial{grid-template-columns:1fr;min-height:auto}.lv-editorial__img{min-height:380px}.lv-editorial__body{padding:56px 40px}}
@media(max-width:768px){.lv-editorial__body{padding:40px 24px}.lv-editorial__title{font-size:1.8rem}.lv-wa{width:48px;height:48px}.lv-wa--left{left:18px}.lv-wa--right{right:18px}#lv-top-btn{bottom:20px;right:18px}}
</style>

<div id="lv-cfg" style="display:none"
    data-asst="{% if theme.settings.get('show_assistant', true) %}1{% else %}0{% endif %}"
    data-spop="{% if theme.settings.get('show_sales_pop', true) %}1{% else %}0{% endif %}"
    data-view="{% if theme.settings.get('show_viewers', true) %}1{% else %}0{% endif %}"
    data-d26="{{ theme.settings.get('assistant_d26_link', '/') }}"
    data-d27="{{ theme.settings.get('assistant_d27_link', '/') }}"
    data-d28="{{ theme.settings.get('assistant_d28_link', '/') }}"
    data-gift="{{ theme.settings.get('assistant_gift_link', '/') }}"
></div>

{% if theme.settings.get('show_splash', true) %}
    {% if theme.settings.get('splash_type', 'gateway') == 'gateway' %}
    <div id="lv-gateway">
        <div class="lv-gw-panel lv-gw-panel--left"></div>
        <div class="lv-gw-panel lv-gw-panel--right"></div>
        <div class="lv-gw-center">
            <div class="lv-gw-line"></div>
            {% if theme.settings.get('splash_image') %}
                <img src="{{ theme.settings.get('splash_image') }}" alt="{{ store.name }}" class="lv-gw-logo">
            {% elseif store.logo %}
                <img src="{{ store.logo }}" alt="{{ store.name }}" class="lv-gw-logo">
            {% else %}
                <div class="lv-gw-text">{{ store.name }}</div>
            {% endif %}
            <div class="lv-gw-sub">{{ theme.settings.get('splash_text', 'Luxury Perfumes') }}</div>
            <div class="lv-gw-line-b"></div>
        </div>
        <button class="lv-gw-btn" id="lv-gw-enter">enter</button>
    </div>
    {% else %}
    <div id="lv-splash" style="position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;background:#fff;animation:splashOut 0.7s ease 2.4s forwards">
        {% if theme.settings.get('splash_image') %}
            <img src="{{ theme.settings.get('splash_image') }}" alt="{{ store.name }}" style="max-width:220px;max-height:130px;object-fit:contain">
        {% elseif store.logo %}
            <img src="{{ store.logo }}" alt="{{ store.name }}" style="max-width:220px;max-height:130px;object-fit:contain">
        {% else %}
            <div style="font-size:2rem;font-weight:200;letter-spacing:10px;color:#1a1a1a">{{ store.name }}</div>
        {% endif %}
    </div>
    <style>@keyframes splashOut{to{opacity:0;visibility:hidden}}</style>
    {% endif %}
{% endif %}

<section class="lv-hero" style="height:100vh">
    {% if theme.settings.get('hero_type') == 'video' and theme.settings.get('hero_video_url') %}
        <video autoplay muted loop playsinline class="lv-hero__video">
            <source src="{{ theme.settings.get('hero_video_url') }}" type="video/mp4">
        </video>
    {% elseif theme.settings.get('hero_type') == 'slider' %}
        <div class="lv-slider">
            {% if theme.settings.get('hero_image') %}<div class="lv-slider__item active"><img src="{{ theme.settings.get('hero_image') }}" alt="slide1"></div>{% endif %}
            {% if theme.settings.get('hero_image_2') %}<div class="lv-slider__item"><img src="{{ theme.settings.get('hero_image_2') }}" alt="slide2"></div>{% endif %}
            {% if theme.settings.get('hero_image_3') %}<div class="lv-slider__item"><img src="{{ theme.settings.get('hero_image_3') }}" alt="slide3"></div>{% endif %}
        </div>
        <div class="lv-slider__dots">
            {% if theme.settings.get('hero_image') %}<button class="lv-slider__dot active"></button>{% endif %}
            {% if theme.settings.get('hero_image_2') %}<button class="lv-slider__dot"></button>{% endif %}
            {% if theme.settings.get('hero_image_3') %}<button class="lv-slider__dot"></button>{% endif %}
        </div>
    {% elseif theme.settings.get('hero_image') %}
        <img src="{{ theme.settings.get('hero_image') }}" alt="{{ store.name }}" class="lv-hero__bg">
    {% else %}
        <div class="lv-hero__bg" style="background:linear-gradient(160deg,#1a1a1a 0%,#2c2416 100%)"></div>
    {% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'light' %}<div class="lv-hero__overlay" style="background:rgba(0,0,0,0.2)"></div>{% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'medium' %}<div class="lv-hero__overlay" style="background:rgba(0,0,0,0.45)"></div>{% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'dark' %}<div class="lv-hero__overlay" style="background:rgba(0,0,0,0.7)"></div>{% endif %}
    {% if theme.settings.get('hero_title') or theme.settings.get('hero_cta_text') %}
    <div class="lv-hero__content">
        {% if theme.settings.get('hero_label') %}<span class="lv-hero__label">{{ theme.settings.get('hero_label') }}</span>{% endif %}
        {% if theme.settings.get('hero_title') %}<h1 class="lv-hero__title">{{ theme.settings.get('hero_title') }}</h1>{% endif %}
        {% if theme.settings.get('hero_subtitle') %}<span class="lv-hero__subtitle">{{ theme.settings.get('hero_subtitle') }}</span>{% endif %}
        {% if theme.settings.get('hero_cta_text') %}<a href="{{ theme.settings.get('hero_cta_link', '/products') }}" class="lv-hero__btn">{{ theme.settings.get('hero_cta_text') }}</a>{% endif %}
    </div>
    {% endif %}
    {% if theme.settings.get('show_hero_scroll', true) %}<div class="lv-hero__scroll"><span></span></div>{% endif %}
</section>

{% component home %}

{% if theme.settings.get('show_mid_banner', true) and theme.settings.get('mid_banner_image') %}
<section style="position:relative;overflow:hidden">
    <a href="{{ theme.settings.get('mid_banner_link', '/products') }}" style="display:block">
        <img src="{{ theme.settings.get('mid_banner_image') }}" alt="banner" style="width:100%;height:auto;display:block;max-height:620px;object-fit:cover">
    </a>
    {% if theme.settings.get('mid_banner_title') %}
    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;text-align:center;padding:24px;pointer-events:none">
        <h2 style="color:#fff;font-size:clamp(1.8rem,4vw,3.5rem);font-weight:200;margin:0 0 28px;letter-spacing:2px">{{ theme.settings.get('mid_banner_title') }}</h2>
        {% if theme.settings.get('mid_banner_cta_text') %}
        <a href="{{ theme.settings.get('mid_banner_link', '/products') }}" style="display:inline-block;padding:13px 44px;border:1px solid #fff;color:#fff;text-decoration:none;font-size:12px;letter-spacing:3px;pointer-events:all">{{ theme.settings.get('mid_banner_cta_text') }}</a>
        {% endif %}
    </div>
    {% endif %}
</section>
{% endif %}

{% if theme.settings.get('show_banner2') and theme.settings.get('banner2_image') %}
<a href="{{ theme.settings.get('banner2_link', '/products') }}" style="display:block;overflow:hidden">
    <img src="{{ theme.settings.get('banner2_image') }}" alt="banner2" style="width:100%;height:auto;display:block">
</a>
{% endif %}

{% if theme.settings.get('show_editorial', true) and theme.settings.get('editorial_image') %}
<section class="lv-editorial">
    <div class="lv-editorial__img"><img src="{{ theme.settings.get('editorial_image') }}" alt="story"></div>
    <div class="lv-editorial__body">
        <p class="lv-editorial__label">{{ theme.settings.get('editorial_label', 'OUR STORY') }}</p>
        <h2 class="lv-editorial__title">{{ theme.settings.get('editorial_title', 'story') }}</h2>
        <p class="lv-editorial__text">{{ theme.settings.get('editorial_text', '') }}</p>
        <a href="{{ theme.settings.get('editorial_cta_link', '/page/about') }}" class="lv-editorial__btn">{{ theme.settings.get('editorial_cta_text', 'more') }}</a>
    </div>
</section>
{% endif %}

{% if theme.settings.get('show_whatsapp_btn', true) and theme.settings.get('whatsapp_number') %}
<a href="https://wa.me/{{ theme.settings.get('whatsapp_number') }}" target="_blank" class="lv-wa lv-wa--{{ theme.settings.get('whatsapp_position', 'left') }}" aria-label="whatsapp">
    <svg width="26" height="26" fill="#fff" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.121 1.533 5.857L.057 23.571l5.866-1.54A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.373l-.36-.214-3.48.913.929-3.395-.234-.349A9.818 9.818 0 012.182 12 9.818 9.818 0 0112 2.182 9.818 9.818 0 0121.818 12 9.818 9.818 0 0112 21.818z"/></svg>
</a>
{% endif %}

{% if theme.settings.get('show_back_to_top', true) %}
<button id="lv-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="top">
    <i class="sicon-chevron-up"></i>
</button>
{% endif %}

{% endblock %}

{% block scripts %}
<script>
(function(){
    var cfg=document.getElementById('lv-cfg');
    var ASST=cfg&&cfg.dataset.asst==='1';
    var SPOP=cfg&&cfg.dataset.spop==='1';
    var VIEW=cfg&&cfg.dataset.view==='1';
    var D26=cfg?cfg.dataset.d26:'/';
    var D27=cfg?cfg.dataset.d27:'/';
    var D28=cfg?cfg.dataset.d28:'/';
    var GIFT=cfg?cfg.dataset.gift:'/';

    var gw=document.getElementById('lv-gateway');
    var gwBtn=document.getElementById('lv-gw-enter');
    function openGW(){if(!gw)return;gw.classList.add('lv-open');setTimeout(function(){gw.classList.add('lv-gone');},900);}
    if(gw){setTimeout(openGW,3200);if(gwBtn)gwBtn.addEventListener('click',openGW);}

    var idx=0;
    var slides=document.querySelectorAll('.lv-slider__item');
    var dots=document.querySelectorAll('.lv-slider__dot');
    function goSlide(n){
        if(!slides.length)return;
        slides.forEach(function(s){s.classList.remove('active');});
        dots.forEach(function(d){d.classList.remove('active');});
        idx=(n+slides.length)%slides.length;
        slides[idx].classList.add('active');
        if(dots[idx])dots[idx].classList.add('active');
    }
    dots.forEach(function(d,i){d.addEventListener('click',function(){goSlide(i);});});
    if(slides.length>1)setInterval(function(){goSlide(idx+1);},5000);

    var tb=document.getElementById('lv-top-btn');
    if(tb)window.addEventListener('scroll',function(){tb.style.display=window.scrollY>400?'flex':'none';},{passive:true});

    if(ASST){
        var acs=document.createElement('style');
        acs.innerHTML='#lv-ab{position:fixed;bottom:20px;left:20px;background:#1a1a1a;color:#fff;padding:10px 18px;z-index:9997;font-weight:bold;cursor:pointer;border:1px solid #C9A84C;font-size:12px;display:flex;align-items:center;font-family:inherit}#lv-ap{position:fixed;bottom:75px;left:20px;width:270px;background:#fff;border:2px solid #1a1a1a;z-index:9997;direction:rtl;font-family:inherit;display:none;box-shadow:0 8px 32px rgba(0,0,0,0.18)}.lv-aph{background:#1a1a1a;color:#fff;padding:10px 15px;display:flex;justify-content:space-between;align-items:center}.lv-apo{display:block;width:100%;padding:9px;margin:5px 0;background:#fff;border:1px solid #1a1a1a;font-weight:bold;cursor:pointer;font-size:11px;transition:0.3s;text-align:center}.lv-apo:hover{background:#1a1a1a;color:#fff}@media(max-width:767px){#lv-ab{padding:8px 14px;font-size:10px;bottom:15px;left:5%}#lv-ap{width:240px;bottom:65px;left:5%}}';
        document.head.appendChild(acs);
        var aEl=document.createElement('div');
        aEl.innerHTML='<div id="lv-ab">\u0645\u062d\u062a\u0627\u0631 \u0648\u0634 \u062a\u062e\u062a\u0627\u0631\u061f</div><div id="lv-ap"><div class="lv-aph"><span style="font-weight:bold;font-size:14px">\u0645\u0633\u0627\u0639\u062f \u0644\u0627\u0641\u064a\u0633\u062a\u0627</span><span id="lv-ax" style="cursor:pointer;font-size:22px;line-height:1">&times;</span></div><div id="lv-aq" style="padding:15px;text-align:center"><p style="font-weight:bold;margin:0 0 12px;font-size:13px">\u0648\u0634 \u062c\u0648\u0643 \u0641\u064a \u0627\u0644\u0639\u0637\u0648\u0631\u061f</p><button class="lv-apo" id="lv-a1">\u0641\u062e\u0645 \u0648\u0631\u0633\u0645\u064a \u0631\u062c\u0627\u0644\u064a</button><button class="lv-apo" id="lv-a2">\u0646\u0627\u0639\u0645 \u0648\u0627\u0646\u062b\u0648\u064a \u0646\u0633\u0627\u0626\u064a</button><button class="lv-apo" id="lv-a3">\u0628\u0627\u0631\u062f \u0648\u0645\u0646\u0639\u0634 \u064a\u0648\u0645\u064a</button><button class="lv-apo" id="lv-a4">\u0628\u0648\u0643\u0633 \u0627\u0644\u0627\u0647\u062f\u0627\u0621</button></div><div id="lv-ar" style="display:none;padding:15px;text-align:center"><h4 id="lv-rt" style="font-size:14px;margin:0 0 8px"></h4><p id="lv-rd" style="font-size:12px;color:#666;margin:0 0 14px"></p><a id="lv-rl" href="#" style="display:block;background:#1a1a1a;color:#fff;padding:10px;text-decoration:none;font-weight:bold;font-size:13px">\u0627\u0637\u0644\u0628\u0647 \u0627\u0644\u0627\u0646</a><button id="lv-rb" style="background:none;border:none;text-decoration:underline;color:#999;margin-top:10px;cursor:pointer;font-size:11px">\u062c\u0631\u0628 \u0645\u0631\u0629 \u062b\u0627\u0646\u064a\u0629</button></div></div>';
        document.body.appendChild(aEl);
        var REC={
            D28:{t:'D28',d:'\u0627\u0644\u0647\u064a\u0628\u0629 \u0648\u0627\u0644\u062d\u0636\u0648\u0631 \u0644\u0644\u0645\u0646\u0627\u0633\u0628\u0627\u062a \u0627\u0644\u0631\u0633\u0645\u064a\u0629',l:D28},
            D26:{t:'D26',d:'\u0639\u0637\u0631 \u0627\u0644\u0627\u0646\u0648\u062b\u0629 \u0648\u0627\u0644\u0631\u0642\u0629',l:D26},
            D27:{t:'D27',d:'\u0627\u0646\u062a\u0639\u0627\u0634 \u064a\u0648\u0645\u064a \u0628\u0627\u0631\u062f \u0648\u0645\u0645\u064a\u0632',l:D27},
            Gift:{t:'\u0628\u0648\u0643\u0633 \u0627\u0644\u0627\u0647\u062f\u0627\u0621',d:'\u0647\u062f\u064a\u0629 \u0641\u062e\u0645\u0629 \u062a\u0628\u064a\u0636 \u0627\u0644\u0648\u062c\u0647',l:GIFT}
        };
        function showR(k){document.getElementById('lv-aq').style.display='none';document.getElementById('lv-ar').style.display='block';document.getElementById('lv-rt').innerText='\u0644\u0627\u0641\u064a\u0633\u062a\u0627 '+REC[k].t;document.getElementById('lv-rd').innerText=REC[k].d;document.getElementById('lv-rl').href=REC[k].l;}
        document.getElementById('lv-ab').onclick=function(){document.getElementById('lv-ap').style.display='block';this.style.display='none';};
        document.getElementById('lv-ax').onclick=function(){document.getElementById('lv-ap').style.display='none';document.getElementById('lv-ab').style.display='flex';};
        document.getElementById('lv-a1').onclick=function(){showR('D28');};
        document.getElementById('lv-a2').onclick=function(){showR('D26');};
        document.getElementById('lv-a3').onclick=function(){showR('D27');};
        document.getElementById('lv-a4').onclick=function(){showR('Gift');};
        document.getElementById('lv-rb').onclick=function(){document.getElementById('lv-aq').style.display='block';document.getElementById('lv-ar').style.display='none';};
    }

    if(SPOP){
        var pcs=document.createElement('style');
        pcs.innerHTML='#lv-sp{position:fixed;bottom:20px;right:20px;background:#fff;width:255px;border-right:4px solid #C9A84C;padding:10px 12px;z-index:9996;display:flex;align-items:center;direction:rtl;transition:transform 0.5s,opacity 0.5s;transform:translateY(100px);opacity:0;font-family:inherit;box-shadow:0 4px 20px rgba(0,0,0,0.12)}#lv-sp.on{transform:translateY(0);opacity:1}@media(max-width:767px){#lv-sp{width:70%;right:4%;bottom:14px}}';
        document.head.appendChild(pcs);
        var spEl=document.createElement('div');
        spEl.id='lv-sp';
        spEl.innerHTML='<div style="width:32px;min-width:32px;margin-left:10px"><svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2" width="32" height="32"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></div><div><p id="lv-st" style="margin:0 0 3px;font-size:12px;line-height:1.4"></p><span style="font-size:10px;color:#27ae60">\u062a\u0645 \u0627\u0644\u062a\u062d\u0642\u0642</span></div>';
        document.body.appendChild(spEl);
        var PN=['\u0639\u0628\u062f\u0627\u0644\u0644\u0647','\u0633\u0627\u0631\u0629','\u0645\u062d\u0645\u062f','\u0646\u0648\u0631\u0629','\u0641\u0647\u062f','\u0631\u064a\u0645','\u062e\u0627\u0644\u062f','\u0645\u0647\u0627','\u0645\u0646\u064a\u0631\u0629','\u0645\u0631\u0627\u0645'];
        var PC=['\u0627\u0644\u0631\u064a\u0627\u0636','\u062c\u062f\u0629','\u0627\u0644\u062f\u0645\u0627\u0645','\u0645\u0643\u0629','\u0627\u0644\u0642\u0635\u064a\u0645','\u0627\u0644\u062e\u0628\u0631','\u062d\u0627\u0626\u0644','\u062a\u0628\u0648\u0643'];
        var PP=['\u0639\u0637\u0631 D26','\u0639\u0637\u0631 D27','\u0639\u0637\u0631 D28','\u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u0643\u0627\u0645\u0644\u0629','\u0628\u0648\u0643\u0633 \u0627\u0644\u0627\u0647\u062f\u0627\u0621'];
        setInterval(function(){
            var n=PN[Math.floor(Math.random()*PN.length)];
            var c=PC[Math.floor(Math.random()*PC.length)];
            var p=PP[Math.floor(Math.random()*PP.length)];
            document.getElementById('lv-st').innerHTML='<strong>'+n+'</strong> \u0645\u0646 <strong>'+c+'</strong> \u0637\u0644\u0628 <strong>'+p+'</strong>';
            spEl.classList.add('on');
            setTimeout(function(){spEl.classList.remove('on');},5500);
        },18000);
    }

    if(VIEW){
        var vcs=document.createElement('style');
        vcs.innerHTML='@keyframes vwblink{0%,100%{opacity:1}50%{opacity:0.25}}';
        document.head.appendChild(vcs);
        setInterval(function(){
            if(document.getElementById('lv-vw'))return;
            if(!window.location.pathname.match(/\/p\d/))return;
            var t=document.querySelector('.product-details__title, .product__title, h1');
            if(!t)return;
            var v=document.createElement('div');
            v.id='lv-vw';
            v.style.cssText='color:#c0392b;font-size:13px;margin:8px 0;display:flex;align-items:center;gap:6px;font-family:inherit';
            var cnt=Math.floor(Math.random()*28)+18;
            v.innerHTML='<span style="width:8px;height:8px;background:#c0392b;border-radius:50%;display:inline-block;animation:vwblink 1.4s infinite"></span>\u064a\u0634\u0627\u0647\u062f \u0647\u0630\u0627 \u0627\u0644\u0645\u0646\u062a\u062c <strong>'+cnt+'</strong> \u0634\u062e\u0635 \u0627\u0644\u0622\u0646';
            t.parentNode.insertBefore(v,t.nextSibling);
        },1500);
    }

})();
</script>
