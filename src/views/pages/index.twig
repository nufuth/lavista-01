{% if theme.settings.get('show_sales_pop', true) %}
<div id="lv-pops">
    <div class="lv-pop-n">سارة من جدة طلبت <strong>عطر D26</strong></div>
    <div class="lv-pop-n">محمد من الرياض طلب <strong>عطر D28</strong></div>
