{% extends "layouts.master" %}

{% block content %}
{% include 'components/lv-styles.twig' %}

{% if theme.settings.get('show_splash', true) %}
    {% if theme.settings.get('splash_type', 'gateway') == 'gateway' %}
    <div id="lv-gateway">
        <div class="lv-gw-panel lv-gw-panel--left"></div>
        <div class="lv-gw-panel lv-gw-panel--right"></div>
        <div class="lv-gw-center">
            <div class="lv-gw-line"></div>
            {% if theme.settings.get('splash_image') %}
                <img src="{{ theme.settings.get('splash_image') }}" alt="{{ store.name }}" class="lv-gw-logo">
            {% elseif store.logo %}
                <img src="{{ store.logo }}" alt="{{ store.name }}" class="lv-gw-logo">
            {% else %}
                <div class="lv-gw-text">{{ store.name }}</div>
            {% endif %}
            <div class="lv-gw-sub">{{ theme.settings.get('splash_text', 'Luxury Perfumes') }}</div>
            <div class="lv-gw-line-b"></div>
        </div>
        <button class="lv-gw-btn" id="lv-gw-enter">enter</button>
    </div>
    {% else %}
    <div id="lv-splash" style="position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;background:#fff;animation:splashOut 0.7s ease 2.4s forwards">
        {% if theme.settings.get('splash_image') %}
            <img src="{{ theme.settings.get('splash_image') }}" alt="{{ store.name }}" style="max-width:220px;max-height:130px;object-fit:contain">
        {% elseif store.logo %}
            <img src="{{ store.logo }}" alt="{{ store.name }}" style="max-width:220px;max-height:130px;object-fit:contain">
        {% else %}
            <div style="font-size:2rem;font-weight:200;letter-spacing:10px;color:#1a1a1a">{{ store.name }}</div>
        {% endif %}
    </div>
    <style>@keyframes splashOut{to{opacity:0;visibility:hidden}}</style>
    {% endif %}
{% endif %}

<section class="lv-hero" style="height:100vh">
    {% if theme.settings.get('hero_type') == 'video' and theme.settings.get('hero_video_url') %}
        <video autoplay muted loop playsinline class="lv-hero__video">
            <source src="{{ theme.settings.get('hero_video_url') }}" type="video/mp4">
        </video>
    {% elseif theme.settings.get('hero_type') == 'slider' %}
        <div class="lv-slider">
            {% if theme.settings.get('hero_image') %}<div class="lv-slider__item active"><img src="{{ theme.settings.get('hero_image') }}" alt="slide1"></div>{% endif %}
            {% if theme.settings.get('hero_image_2') %}<div class="lv-slider__item"><img src="{{ theme.settings.get('hero_image_2') }}" alt="slide2"></div>{% endif %}
            {% if theme.settings.get('hero_image_3') %}<div class="lv-slider__item"><img src="{{ theme.settings.get('hero_image_3') }}" alt="slide3"></div>{% endif %}
        </div>
        <div class="lv-slider__dots">
            {% if theme.settings.get('hero_image') %}<button class="lv-slider__dot active"></button>{% endif %}
            {% if theme.settings.get('hero_image_2') %}<button class="lv-slider__dot"></button>{% endif %}
            {% if theme.settings.get('hero_image_3') %}<button class="lv-slider__dot"></button>{% endif %}
        </div>
    {% elseif theme.settings.get('hero_image') %}
        <img src="{{ theme.settings.get('hero_image') }}" alt="{{ store.name }}" class="lv-hero__bg">
    {% else %}
        <div class="lv-hero__bg" style="background:linear-gradient(160deg,#1a1a1a 0%,#2c2416 100%)"></div>
    {% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'light' %}<div class="lv-hero__overlay" style="background:rgba(0,0,0,0.2)"></div>{% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'medium' %}<div class="lv-hero__overlay" style="background:rgba(0,0,0,0.45)"></div>{% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'dark' %}<div class="lv-hero__overlay" style="background:rgba(0,0,0,0.7)"></div>{% endif %}
    {% if theme.settings.get('hero_title') or theme.settings.get('hero_cta_text') %}
    <div class="lv-hero__content">
        {% if theme.settings.get('hero_label') %}<span class="lv-hero__label">{{ theme.settings.get('hero_label') }}</span>{% endif %}
        {% if theme.settings.get('hero_title') %}<h1 class="lv-hero__title">{{ theme.settings.get('hero_title') }}</h1>{% endif %}
        {% if theme.settings.get('hero_subtitle') %}<span class="lv-hero__subtitle">{{ theme.settings.get('hero_subtitle') }}</span>{% endif %}
        {% if theme.settings.get('hero_cta_text') %}<a href="{{ theme.settings.get('hero_cta_link', '/products') }}" class="lv-hero__btn">{{ theme.settings.get('hero_cta_text') }}</a>{% endif %}
    </div>
    {% endif %}
    {% if theme.settings.get('show_hero_scroll', true) %}<div class="lv-hero__scroll"><span></span></div>{% endif %}
</section>

{% component home %}

{% if theme.settings.get('show_mid_banner', true) and theme.settings.get('mid_banner_image') %}
<section style="position:relative;overflow:hidden">
    <a href="{{ theme.settings.get('mid_banner_link', '/products') }}" style="display:block">
        <img src="{{ theme.settings.get('mid_banner_image') }}" alt="banner" style="width:100%;height:auto;display:block;max-height:620px;object-fit:cover">
    </a>
    {% if theme.settings.get('mid_banner_title') %}
    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;text-align:center;padding:24px;pointer-events:none">
        <h2 style="color:#fff;font-size:clamp(1.8rem,4vw,3.5rem);font-weight:200;margin:0 0 28px;letter-spacing:2px">{{ theme.settings.get('mid_banner_title') }}</h2>
        {% if theme.settings.get('mid_banner_cta_text') %}
        <a href="{{ theme.settings.get('mid_banner_link', '/products') }}" style="display:inline-block;padding:13px 44px;border:1px solid #fff;color:#fff;text-decoration:none;font-size:12px;letter-spacing:3px;pointer-events:all">{{ theme.settings.get('mid_banner_cta_text') }}</a>
        {% endif %}
    </div>
    {% endif %}
</section>
{% endif %}

{% if theme.settings.get('show_banner2') and theme.settings.get('banner2_image') %}
<a href="{{ theme.settings.get('banner2_link', '/products') }}" style="display:block;overflow:hidden">
    <img src="{{ theme.settings.get('banner2_image') }}" alt="banner2" style="width:100%;height:auto;display:block">
</a>
{% endif %}

{% if theme.settings.get('show_editorial', true) and theme.settings.get('editorial_image') %}
<section class="lv-editorial">
    <div class="lv-editorial__img"><img src="{{ theme.settings.get('editorial_image') }}" alt="story"></div>
    <div class="lv-editorial__body">
        <p class="lv-editorial__label">{{ theme.settings.get('editorial_label', 'OUR STORY') }}</p>
        <h2 class="lv-editorial__title">{{ theme.settings.get('editorial_title', 'story') }}</h2>
        <p class="lv-editorial__text">{{ theme.settings.get('editorial_text', '') }}</p>
        <a href="{{ theme.settings.get('editorial_cta_link', '/page/about') }}" class="lv-editorial__btn">{{ theme.settings.get('editorial_cta_text', 'more') }}</a>
    </div>
</section>
{% endif %}

{% if theme.settings.get('show_whatsapp_btn', true) and theme.settings.get('whatsapp_number') %}
<a href="https://wa.me/{{ theme.settings.get('whatsapp_number') }}" target="_blank" class="lv-wa lv-wa--{{ theme.settings.get('whatsapp_position', 'left') }}" aria-label="whatsapp">
    <svg width="26" height="26" fill="#fff" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.121 1.533 5.857L.057 23.571l5.866-1.54A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.373l-.36-.214-3.48.913.929-3.395-.234-.349A9.818 9.818 0 012.182 12 9.818 9.818 0 0112 2.182 9.818 9.818 0 0121.818 12 9.818 9.818 0 0112 21.818z"/></svg>
</a>
{% endif %}

{% if theme.settings.get('show_back_to_top', true) %}
<button id="lv-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="top">
    <i class="sicon-chevron-up"></i>
</button>
{% endif %}

{% include 'components/marketing-tools.twig' %}

{% endblock %}

{% block scripts %}
<script>
(function(){
    var gw=document.getElementById('lv-gateway');
    var gwBtn=document.getElementById('lv-gw-enter');
    function openGW(){if(!gw)return;gw.classList.add('lv-open');setTimeout(function(){gw.classList.add('lv-gone');},900);}
    if(gw){setTimeout(openGW,3200);if(gwBtn)gwBtn.addEventListener('click',openGW);}
    var idx=0;
    var slides=document.querySelectorAll('.lv-slider__item');
    var dots=document.querySelectorAll('.lv-slider__dot');
    function goSlide(n){
        if(!slides.length)return;
        slides.forEach(function(s){s.classList.remove('active');});
        dots.forEach(function(d){d.classList.remove('active');});
        idx=(n+slides.length)%slides.length;
        slides[idx].classList.add('active');
        if(dots[idx])dots[idx].classList.add('active');
    }
    dots.forEach(function(d,i){d.addEventListener('click',function(){goSlide(i);});});
    if(slides.length>1)setInterval(function(){goSlide(idx+1);},5000);
    var tb=document.getElementById('lv-top-btn');
    if(tb)window.addEventListener('scroll',function(){tb.style.display=window.scrollY>400?'flex':'none';},{passive:true});
})();
</script>
{% endblock %}
