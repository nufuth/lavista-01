{% extends 'layouts.master' %}

{% block content %}

    {# الهيرو #}
    {% set hero_h = {'fullscreen':'100vh','large':'80vh','medium':'60vh'}[theme.settings.get('hero_height','fullscreen')] | default('100vh') %}
    {% set hero_overlay = {'none':'0','light':'0.25','medium':'0.5','dark':'0.75'}[theme.settings.get('hero_overlay_opacity','medium')] | default('0.5') %}
    {% set hero_image = theme.settings.get('hero_image','') %}
    {% set hero_video = theme.settings.get('hero_video_url','') %}
    {% set hero_type  = theme.settings.get('hero_type','image') %}

    <section style="position:relative;overflow:hidden;height:{{ hero_h }};min-height:480px;">

        {% if hero_type == 'video' and hero_video != '' %}
            <video autoplay muted loop playsinline style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
                <source src="{{ hero_video }}" type="video/mp4">
            </video>
        {% elseif hero_image != '' %}
            <img src="{{ hero_image }}" alt="hero" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        {% else %}
            <div style="position:absolute;inset:0;background:#1a1a1a;"></div>
        {% endif %}

        <div style="position:absolute;inset:0;background:#000;opacity:{{ hero_overlay }};"></div>

        <div style="position:relative;z-index:2;height:100%;display:flex;align-items:flex-end;padding:0 24px 80px;">
            <div>
                <p style="color:#C9A84C;letter-spacing:4px;font-size:12px;margin:0 0 12px;text-transform:uppercase;">
                    {{ theme.settings.get('hero_label','THE NEW COLLECTION') }}
                </p>
                <h1 style="color:#fff;font-size:clamp(2rem,6vw,5rem);font-weight:300;margin:0 0 16px;line-height:1.1;">
                    {{ theme.settings.get('hero_title','LAVISTA') }}
                </h1>
                <p style="color:rgba(255,255,255,0.8);font-size:1rem;margin:0 0 32px;">
                    {{ theme.settings.get('hero_subtitle','عطر أسطوري يُعيد تعريف الفخامة') }}
                </p>
                <a href="{{ theme.settings.get('hero_cta_link','/products') }}"
                   style="display:inline-block;background:#fff;color:#1a1a1a;padding:14px 40px;text-decoration:none;font-weight:600;letter-spacing:1px;">
                    {{ theme.settings.get('hero_cta_text','اكتشف الآن') }}
                </a>
            </div>
        </div>
    </section>

    {# وصل حديثاً #}
    {% if theme.settings.get('show_new_arrivals',true) %}
    <section style="padding:80px 24px;background:#fff;max-width:1200px;margin:0 auto;">
        <h2 style="font-size:2rem;font-weight:300;color:#1a1a1a;margin:0 0 48px;">
            {{ theme.settings.get('new_arrivals_title','وصل حديثاً') }}
        </h2>
        {% component 'product.featured' with {'source': 'latest', 'count': 8} %}
    </section>
    {% endif %}

    {# البانر الوسطي #}
    {% if theme.settings.get('show_mid_banner',true) %}
    {% set mid_img = theme.settings.get('mid_banner_image','') %}
    <section style="position:relative;min-height:460px;display:flex;align-items:center;
        background:{% if mid_img != '' %}url('{{ mid_img }}') center/cover no-repeat{% else %}#1a1a1a{% endif %};">
        <div style="position:absolute;inset:0;background:#000;opacity:0.55;"></div>
        <div style="position:relative;z-index:2;text-align:center;padding:80px 24px;width:100%;">
            <p style="color:#C9A84C;letter-spacing:4px;font-size:12px;text-transform:uppercase;margin:0 0 16px;">
                {{ theme.settings.get('mid_banner_label_text','EXCLUSIVE COLLECTION') }}
            </p>
            <h2 style="color:#fff;font-size:clamp(1.8rem,5vw,3.5rem);font-weight:300;margin:0 0 20px;">
                {{ theme.settings.get('mid_banner_title','عطرك يُعرّفك') }}
            </h2>
            <p style="color:rgba(255,255,255,0.8);margin:0 0 40px;max-width:560px;margin-left:auto;margin-right:auto;">
                {{ theme.settings.get('mid_banner_text','') }}
            </p>
            <a href="{{ theme.settings.get('mid_banner_cta_link','/products') }}"
               style="display:inline-block;border:1px solid #fff;color:#fff;padding:14px 48px;text-decoration:none;letter-spacing:2px;">
                {{ theme.settings.get('mid_banner_cta_text','تسوق الآن') }}
            </a>
        </div>
    </section>
    {% endif %}

    {# الأكثر مبيعاً #}
    {% if theme.settings.get('show_bestsellers',true) %}
    <section style="padding:80px 24px;background:#f9f7f4;max-width:1200px;margin:0 auto;">
        <h2 style="font-size:2rem;font-weight:300;color:#1a1a1a;margin:0 0 48px;">
            {{ theme.settings.get('bestsellers_title','الأكثر مبيعاً') }}
        </h2>
        {% component 'product.featured' with {'source': 'best_selling', 'count': 8} %}
    </section>
    {% endif %}

    {# واتساب عائم #}
    {% if theme.settings.get('show_whatsapp_btn',true) %}
    {% set wa = theme.settings.get('whatsapp_number','') %}
    {% if wa != '' %}
    <a href="https://wa.me/{{ wa }}" target="_blank"
       style="position:fixed;bottom:30px;left:30px;z-index:9999;width:56px;height:56px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.5);text-decoration:none;">
        <svg width="26" height="26" fill="#fff" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.121 1.533 5.857L.057 23.571l5.866-1.54A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.373l-.36-.214-3.48.913.929-3.395-.234-.349A9.818 9.818 0 012.182 12 9.818 9.818 0 0112 2.182 9.818 9.818 0 0121.818 12 9.818 9.818 0 0112 21.818z"/></svg>
    </a>
    {% endif %}
    {% endif %}

{% endblock %}
