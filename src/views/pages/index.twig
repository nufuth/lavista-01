{% extends "layouts.master" %}

{% block content %}
<style>
#lv-gateway{position:fixed;inset:0;z-index:99999;pointer-events:all}
.lv-gw-panel{position:absolute;top:0;bottom:0;width:50%;background:#0e0d0c;transition:transform 1.1s cubic-bezier(0.77,0,0.18,1)}
.lv-gw-panel--left{left:0}
.lv-gw-panel--right{right:0}
.lv-gw-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:2;pointer-events:none}
.lv-gw-line{width:0;height:1px;background:#C9A84C;margin-bottom:40px;animation:gwLine 1.2s ease 0.3s forwards}
.lv-gw-line-b{width:0;height:1px;background:#C9A84C;margin-top:40px;animation:gwLine 1.2s ease 0.3s forwards}
@keyframes gwLine{to{width:180px}}
.lv-gw-logo{max-width:200px;max-height:90px;object-fit:contain;opacity:0;animation:gwFadeIn 0.9s ease 0.8s forwards}
.lv-gw-text{color:#fff;font-size:2rem;font-weight:200;letter-spacing:12px;text-transform:uppercase;opacity:0;animation:gwFadeIn 0.9s ease 0.8s forwards}
.lv-gw-sub{color:#C9A84C;font-size:10px;letter-spacing:5px;text-transform:uppercase;margin-top:14px;opacity:0;animation:gwFadeIn 0.9s ease 1.1s forwards}
.lv-gw-enter{position:absolute;bottom:48px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.45);font-size:10px;letter-spacing:4px;text-transform:uppercase;opacity:0;animation:gwFadeIn 0.8s ease 1.8s forwards;border:none;background:transparent;cursor:pointer;z-index:3;padding:10px 24px}
@keyframes gwFadeIn{to{opacity:1}}
#lv-gateway.lv-open .lv-gw-panel--left{transform:translateX(-100%)}
#lv-gateway.lv-open .lv-gw-panel--right{transform:translateX(100%)}
#lv-gateway.lv-gone{opacity:0;pointer-events:none;transition:opacity 0.4s ease 0.9s}
#lv-splash{position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;flex-direction:column;pointer-events:none;animation:splashFade 0.7s ease 2.4s forwards}
#lv-splash img{max-width:220px;max-height:130px;object-fit:contain;animation:splashScale 1s ease}
@keyframes splashFade{to{opacity:0;visibility:hidden}}
@keyframes splashScale{from{opacity:0;transform:scale(0.9)}to{opacity:1;transform:scale(1)}}
.lv-hero{position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:460px}
.lv-hero__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.lv-hero__video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.lv-hero__overlay{position:absolute;inset:0}
.lv-hero__content{position:relative;z-index:2;text-align:center;padding:0 24px}
.lv-hero__label{color:#C9A84C;letter-spacing:5px;font-size:11px;text-transform:uppercase;margin:0 0 16px;display:block}
.lv-hero__title{color:#fff;font-size:clamp(2rem,6vw,5rem);font-weight:200;margin:0 0 16px;line-height:1.05;letter-spacing:2px}
.lv-hero__subtitle{color:rgba(255,255,255,0.82);font-size:1rem;margin:0 0 36px;display:block}
.lv-hero__btn{display:inline-block;padding:14px 48px;background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.8);text-decoration:none;font-size:13px;letter-spacing:3px;text-transform:uppercase;transition:all 0.3s}
.lv-hero__btn:hover{background:#fff;color:#1a1a1a}
.lv-slider{position:absolute;inset:0}
.lv-slider__item{position:absolute;inset:0;opacity:0;transition:opacity 1s ease}
.lv-slider__item.active{opacity:1}
.lv-slider__item img{width:100%;height:100%;object-fit:cover}
.lv-slider__dots{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:3}
.lv-slider__dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,0.4);border:none;cursor:pointer;padding:0;transition:background 0.3s}
.lv-slider__dot.active{background:#fff}
.lv-hero__scroll{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center}
.lv-hero__scroll span{display:block;width:1px;height:52px;background:rgba(255,255,255,0.45);animation:scrollLine 1.8s ease infinite}
@keyframes scrollLine{0%,100%{transform:scaleY(1);opacity:1}50%{transform:scaleY(0.3);opacity:0.3}}
.lv-editorial{display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:560px}
.lv-editorial__img{overflow:hidden}
.lv-editorial__img img{width:100%;height:100%;object-fit:cover;display:block}
.lv-editorial__body{background:#f9f7f4;display:flex;flex-direction:column;justify-content:center;padding:80px 64px}
.lv-editorial__label{color:#C9A84C;letter-spacing:5px;font-size:11px;text-transform:uppercase;margin:0 0 20px}
.lv-editorial__title{font-size:2.2rem;font-weight:200;color:#1a1a1a;margin:0 0 24px;line-height:1.2}
.lv-editorial__text{color:#666;line-height:1.9;margin:0 0 40px;font-size:15px}
.lv-editorial__btn{display:inline-block;padding:12px 36px;border:1px solid #1a1a1a;color:#1a1a1a;text-decoration:none;font-size:12px;letter-spacing:2px;text-transform:uppercase;transition:all 0.3s;width:fit-content}
.lv-editorial__btn:hover{background:#1a1a1a;color:#fff}
.lv-wa{position:fixed;bottom:28px;z-index:9999;width:54px;height:54px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.4);transition:transform 0.2s}
.lv-wa:hover{transform:scale(1.1)}
.lv-wa--left{left:26px}
.lv-wa--right{right:26px}
#lv-top-btn{position:fixed;bottom:28px;right:26px;z-index:9998;width:44px;height:44px;background:#1a1a1a;color:#fff;border:none;cursor:pointer;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:18px;box-shadow:0 4px 16px rgba(0,0,0,0.2);transition:background 0.2s}
#lv-top-btn:hover{background:#C9A84C}
@media(max-width:1024px){.lv-editorial{grid-template-columns:1fr;min-height:auto}.lv-editorial__img{min-height:380px}.lv-editorial__body{padding:56px 40px}}
@media(max-width:768px){.lv-editorial__body{padding:40px 24px}.lv-editorial__title{font-size:1.8rem}.lv-wa{width:48px;height:48px;bottom:20px}.lv-wa--left{left:18px}.lv-wa--right{right:18px}#lv-top-btn{bottom:20px;right:18px}}
</style>

{% if theme.settings.get('show_splash', true) %}
    {% if theme.settings.get('splash_type', 'gateway') == 'gateway' %}
    <div id="lv-gateway">
        <div class="lv-gw-panel lv-gw-panel--left"></div>
        <div class="lv-gw-panel lv-gw-panel--right"></div>
        <div class="lv-gw-center">
            <div class="lv-gw-line"></div>
            {% if theme.settings.get('splash_image') %}
                <img src="{{ theme.settings.get('splash_image') }}" alt="{{ store.name }}" class="lv-gw-logo">
            {% elseif store.logo %}
                <img src="{{ store.logo }}" alt="{{ store.name }}" class="lv-gw-logo">
            {% else %}
                <div class="lv-gw-text">{{ store.name }}</div>
            {% endif %}
            <div class="lv-gw-sub">{{ theme.settings.get('splash_text', 'Luxury Perfumes') }}</div>
            <div class="lv-gw-line-b"></div>
        </div>
        <button class="lv-gw-enter" id="lv-gw-btn">ادخل المتجر</button>
    </div>
    {% else %}
    <div id="lv-splash" style="background:#fff">
        {% if theme.settings.get('splash_image') %}
            <img src="{{ theme.settings.get('splash_image') }}" alt="{{ store.name }}">
        {% elseif store.logo %}
            <img src="{{ store.logo }}" alt="{{ store.name }}">
        {% else %}
            <div style="font-size:2rem;font-weight:200;letter-spacing:10px;color:#1a1a1a">{{ store.name }}</div>
        {% endif %}
    </div>
    {% endif %}
{% endif %}

<section class="lv-hero" style="height:100vh">
    {% if theme.settings.get('hero_type') == 'video' and theme.settings.get('hero_video_url') %}
        <video autoplay muted loop playsinline class="lv-hero__video">
            <source src="{{ theme.settings.get('hero_video_url') }}" type="video/mp4">
        </video>
    {% elseif theme.settings.get('hero_type') == 'slider' %}
        <div class="lv-slider">
            {% if theme.settings.get('hero_image') %}<div class="lv-slider__item active"><img src="{{ theme.settings.get('hero_image') }}" alt="1"></div>{% endif %}
            {% if theme.settings.get('hero_image_2') %}<div class="lv-slider__item"><img src="{{ theme.settings.get('hero_image_2') }}" alt="2"></div>{% endif %}
            {% if theme.settings.get('hero_image_3') %}<div class="lv-slider__item"><img src="{{ theme.settings.get('hero_image_3') }}" alt="3"></div>{% endif %}
        </div>
        <div class="lv-slider__dots">
            {% if theme.settings.get('hero_image') %}<button class="lv-slider__dot active"></button>{% endif %}
            {% if theme.settings.get('hero_image_2') %}<button class="lv-slider__dot"></button>{% endif %}
            {% if theme.settings.get('hero_image_3') %}<button class="lv-slider__dot"></button>{% endif %}
        </div>
    {% elseif theme.settings.get('hero_image') %}
        <img src="{{ theme.settings.get('hero_image') }}" alt="{{ store.name }}" class="lv-hero__bg">
    {% else %}
        <div class="lv-hero__bg" style="background:linear-gradient(160deg,#1a1a1a 0%,#2c2416 100%)"></div>
    {% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'light' %}<div class="lv-hero__overlay" style="background:#000;opacity:0.2"></div>{% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'medium' %}<div class="lv-hero__overlay" style="background:#000;opacity:0.45"></div>{% endif %}
    {% if theme.settings.get('hero_overlay_opacity') == 'dark' %}<div class="lv-hero__overlay" style="background:#000;opacity:0.7"></div>{% endif %}
    {% if theme.settings.get('hero_title') or theme.settings.get('hero_cta_text') %}
    <div class="lv-hero__content">
        {% if theme.settings.get('hero_label') %}<span class="lv-hero__label">{{ theme.settings.get('hero_label') }}</span>{% endif %}
        {% if theme.settings.get('hero_title') %}<h1 class="lv-hero__title">{{ theme.settings.get('hero_title') }}</h1>{% endif %}
        {% if theme.settings.get('hero_subtitle') %}<span class="lv-hero__subtitle">{{ theme.settings.get('hero_subtitle') }}</span>{% endif %}
        {% if theme.settings.get('hero_cta_text') %}<a href="{{ theme.settings.get('hero_cta_link', '/products') }}" class="lv-hero__btn">{{ theme.settings.get('hero_cta_text') }}</a>{% endif %}
    </div>
    {% endif %}
    {% if theme.settings.get('show_hero_scroll', true) %}<div class="lv-hero__scroll"><span></span></div>{% endif %}
</section>

{% component home %}

{% if theme.settings.get('show_mid_banner', true) and theme.settings.get('mid_banner_image') %}
<section style="position:relative;overflow:hidden">
    <a href="{{ theme.settings.get('mid_banner_link', '/products') }}" style="display:block">
        <img src="{{ theme.settings.get('mid_banner_image') }}" alt="banner" style="width:100%;height:auto;display:block;max-height:620px;object-fit:cover">
    </a>
    {% if theme.settings.get('mid_banner_title') %}
    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;text-align:center;padding:24px;pointer-events:none">
        <h2 style="color:#fff;font-size:clamp(1.8rem,4vw,3.5rem);font-weight:200;margin:0 0 28px;letter-spacing:2px">{{ theme.settings.get('mid_banner_title') }}</h2>
        {% if theme.settings.get('mid_banner_cta_text') %}
        <a href="{{ theme.settings.get('mid_banner_link', '/products') }}" style="display:inline-block;padding:13px 44px;border:1px solid #fff;color:#fff;text-decoration:none;font-size:12px;letter-spacing:3px;pointer-events:all">{{ theme.settings.get('mid_banner_cta_text') }}</a>
        {% endif %}
    </div>
    {% endif %}
</section>
{% endif %}

{% if theme.settings.get('show_banner2') and theme.settings.get('banner2_image') %}
<a href="{{ theme.settings.get('banner2_link', '/products') }}" style="display:block;overflow:hidden">
    <img src="{{ theme.settings.get('banner2_image') }}" alt="banner2" style="width:100%;height:auto;display:block">
</a>
{% endif %}

{% if theme.settings.get('show_editorial', true) and theme.settings.get('editorial_image') %}
<section class="lv-editorial">
    <div class="lv-editorial__img"><img src="{{ theme.settings.get('editorial_image') }}" alt="editorial"></div>
    <div class="lv-editorial__body">
        <p class="lv-editorial__label">{{ theme.settings.get('editorial_label', 'OUR STORY') }}</p>
        <h2 class="lv-editorial__title">{{ theme.settings.get('editorial_title', 'فن العطر الفاخر') }}</h2>
        <p class="lv-editorial__text">{{ theme.settings.get('editorial_text', '') }}</p>
        <a href="{{ theme.settings.get('editorial_cta_link', '/page/about') }}" class="lv-editorial__btn">{{ theme.settings.get('editorial_cta_text', 'اعرف اكثر') }}</a>
    </div>
</section>
{% endif %}

{% if theme.settings.get('show_whatsapp_btn', true) and theme.settings.get('whatsapp_number') %}
<a href="https://wa.me/{{ theme.settings.get('whatsapp_number') }}" target="_blank" class="lv-wa lv-wa--{{ theme.settings.get('whatsapp_position', 'left') }}" aria-label="whatsapp">
    <svg width="26" height="26" fill="#fff" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.121 1.533 5.857L.057 23.571l5.866-1.54A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.373l-.36-.214-3.48.913.929-3.395-.234-.349A9.818 9.818 0 012.182 12 9.818 9.818 0 0112 2.182 9.818 9.818 0 0121.818 12 9.818 9.818 0 0112 21.818z"/></svg>
</a>
{% endif %}

{% if theme.settings.get('show_back_to_top', true) %}
<button id="lv-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="top">
    <i class="sicon-chevron-up"></i>
</button>
{% endif %}

{% endblock %}

{% block scripts %}
<script>
(function(){
    var gw=document.getElementById('lv-gateway');
    var gwBtn=document.getElementById('lv-gw-btn');
    function openGW(){if(!gw)return;gw.classList.add('lv-open');setTimeout(function(){gw.classList.add('lv-gone');},900);}
    if(gw){setTimeout(openGW,3200);if(gwBtn)gwBtn.addEventListener('click',openGW);}
    var lvIdx=0,items=document.querySelectorAll('.lv-slider__item'),dots=document.querySelectorAll('.lv-slider__dot');
    function lvSlide(n){if(!items.length)return;items.forEach(function(e){e.classList.remove('active');});dots.forEach(function(e){e.classList.remove('active');});lvIdx=(n+items.length)%items.length;items[lvIdx].classList.add('active');if(dots[lvIdx])dots[lvIdx].classList.add('active');}
    dots.forEach(function(d,i){d.addEventListener('click',function(){lvSlide(i);});});
    if(items.length>1)setInterval(function(){lvSlide(lvIdx+1);},5000);
    var tb=document.getElementById('lv-top-btn');
    if(tb)window.addEventListener('scroll',function(){tb.style.display=window.scrollY>400?'flex':'none';},{passive:true});

    var ASST=false,SPOP=false,VIEW=false;
    {% if theme.settings.get('show_assistant', true) %}ASST=true;{% endif %}
    {% if theme.settings.get('show_sales_pop', true) %}SPOP=true;{% endif %}
    {% if theme.settings.get('show_viewers', true) %}VIEW=true;{% endif %}
    var D26="{{ theme.settings.get('assistant_d26_link', '/') }}";
    var D27="{{ theme.settings.get('assistant_d27_link', '/') }}";
    var D28="{{ theme.settings.get('assistant_d28_link', '/') }}";
    var GIFT="{{ theme.settings.get('assistant_gift_link', '/') }}";

    if(ASST){
        var as=document.createElement('style');
        as.innerHTML='#lv-ab{position:fixed;bottom:20px;left:20px;background:#000;color:#fff;padding:10px 18px;z-index:99997;font-weight:bold;cursor:pointer;border:1px solid #fff;font-size:12px;display:flex;align-items:center;font-family:inherit}#lv-ap{position:fixed;bottom:75px;left:20px;width:270px;background:#fff;border:2px solid #000;z-index:99997;direction:rtl;font-family:inherit;display:none}.lv-ph{background:#000;color:#fff;padding:10px 15px;display:flex;justify-content:space-between;align-items:center}.lv-ao{display:block;width:100%;padding:8px;margin:6px 0;background:#fff;border:1px solid #000;font-weight:bold;cursor:pointer;font-size:11px;transition:0.3s}.lv-ao:hover{background:#000;color:#fff}@media(max-width:767px){#lv-ab{padding:8px 14px;font-size:10px;bottom:15px;left:5%}#lv-ap{width:240px;bottom:65px;left:5%}}';
        document.head.appendChild(as);
        var aw=document.createElement('div');
        aw.innerHTML='<div id="lv-ab">محتار وش تختار؟</div><div id="lv-ap"><div class="lv-ph"><span style="font-weight:bold;font-size:14px">مساعد لافيستا</span><span id="lv-ac" style="cursor:pointer;font-size:20px">x</span></div><div id="lv-s1" style="padding:15px;text-align:center"><p style="font-weight:bold;margin-bottom:12px;font-size:13px">وش جوك في العطور؟</p><button class="lv-ao" id="lv-o1">فخم ورسمي رجالي</button><button class="lv-ao" id="lv-o2">ناعم وانثوي نسائي</button><button class="lv-ao" id="lv-o3">بارد ومنعش يومي</button><button class="lv-ao" id="lv-o4">بوكس الاهداء</button></div><div id="lv-s2" style="display:none;padding:15px;text-align:center"><h4 id="lv-rt" style="font-size:14px;margin-bottom:10px"></h4><p id="lv-rd" style="font-size:12px;color:#666;margin-bottom:15px"></p><a id="lv-rl" href="#" style="display:block;background:#000;color:#fff;padding:10px;text-decoration:none;font-weight:bold;font-size:13px">اطلبه الان</a><button id="lv-rb" style="background:none;border:none;text-decoration:underline;color:#999;margin-top:10px;cursor:pointer;font-size:11px">جرب مرة ثانية</button></div></div>';
        document.body.appendChild(aw);
        var data={D28:{t:'لافيستا D28',d:'الهيبة والحضور للمناسبات الرسمية.',l:D28},D26:{t:'لافيستا D26',d:'عطر الانوثة والرقة.. مزيج انثوي خيالي.',l:D26},D27:{t:'لافيستا D27',d:'انتعاش يومي بارد ومميز.',l:D27},Gift:{t:'بوكس الاهداء',d:'هدية فخمة تبيض الوجه وتجمل محتواها.',l:GIFT}};
        function showR(id){document.getElementById('lv-s1').style.display='none';document.getElementById('lv-s2').style.display='block';document.getElementById('lv-rt').innerText=data[id].t;document.getElementById('lv-rd').innerText=data[id].d;document.getElementById('lv-rl').href=data[id].l;}
        document.getElementById('lv-ab').addEventListener('click',function(){document.getElementById('lv-ap').style.display='block';this.style.display='none';});
        document.getElementById('lv-ac').addEventListener('click',function(){document.getElementById('lv-ap').style.display='none';document.getElementById('lv-ab').style.display='flex';});
        document.getElementById('lv-o1').addEventListener('click',function(){showR('D28');});
        document.getElementById('lv-o2').addEventListener('click',function(){showR('D26');});
        document.getElementById('lv-o3').addEventListener('click',function(){showR('D27');});
        document.getElementById('lv-o4').addEventListener('click',function(){showR('Gift');});
        document.getElementById('lv-rb').addEventListener('click',function(){document.getElementById('lv-s1').style.display='block';document.getElementById('lv-s2').style.display='none';});
    }

    if(SPOP){
        var ps=document.createElement('style');
        ps.innerHTML='#lv-sp{position:fixed;bottom:20px;right:20px;background:#fff;width:260px;border:2px solid #000;padding:10px;z-index:99996;display:flex;align-items:center;direction:rtl;transition:0.5s;transform:translateY(150px);opacity:0;font-family:inherit}#lv-sp.on{transform:translateY(0);opacity:1}@media(max-width:767px){#lv-sp{width:70%;right:5%;bottom:15px;padding:6px 10px}}';
        document.head.appendChild(ps);
        var sp=document.createElement('div');
        sp.id='lv-sp';
        sp.innerHTML='<div style="width:35px;margin-left:10px;flex-shrink:0"><img src="https://cdn-icons-png.flaticon.com/512/2956/2956820.png" style="width:100%"></div><div><p id="lv-st" style="margin:0;font-size:12px"></p><span style="font-size:9px;color:#27ae60;background:#eafaf1;padding:2px 5px;margin-top:3px;display:inline-block">شراء موثق</span></div>';
        document.body.appendChild(sp);
        var ns=["عبدالله","سارة","محمد","نورة","فهد","ريم","خالد","مها","منيرة","مرام","غيث","سالم","هيثم","بندر"];
        var cs=["الرياض","جدة","الدمام","مكة","القصيم","الخبر","حائل","تبوك","ابها"];
        var pr=["عطر لافيستا D26","عطر لافيستا D27","عطر لافيستا D28","المجموعة الكاملة","بوكس الاهداء"];
        setInterval(function(){
            var n=ns[Math.floor(Math.random()*ns.length)],c=cs[Math.floor(Math.random()*cs.length)],p=pr[Math.floor(Math.random()*pr.length)];
            document.getElementById('lv-st').innerHTML='<strong>'+n+'</strong> من <strong>'+c+'</strong><br>طلب <strong>'+p+'</strong>';
            sp.classList.add('on');setTimeout(function(){sp.classList.remove('on');},6000);
        },22000);
    }

    if(VIEW){
        var vs=document.createElement('style');
        vs.innerHTML='@keyframes lv-blink{0%,100%{opacity:1}50%{opacity:0.3}}';
        document.head.appendChild(vs);
        setInterval(function(){
            if(document.getElementById('lv-vw'))return;
            if(!window.location.pathname.includes('/p'))return;
            var t=document.querySelector('.product-details__title')||document.querySelector('h1');
            if(!t)return;
            var v=document.createElement('div');
            v.id='lv-vw';
            v.style.cssText='color:#d32f2f;font-weight:bold;font-size:13px;margin:10px 0;display:flex;align-items:center;font-family:inherit';
            v.innerHTML='<span style="width:7px;height:7px;background:#d32f2f;border-radius:50%;margin-left:7px;animation:lv-blink 1.5s infinite;flex-shrink:0"></span> يشاهد هذا المنتج <strong style="margin:0 4px">'+(Math.floor(Math.random()*25)+25)+'</strong> شخص الان';
            t.parentNode.insertBefore(v,t.nextSibling);
        },2000);
    }
})();
</script>
{% endblock %}
