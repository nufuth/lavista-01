{% extends "layouts.master" %}

{# ============================================================
   STYLES — يجب أن يكون في <head> عبر {% block styles %}
   لا نلمس أبدًا: .store-header, .top-navbar, #mainnav,
   .main-nav-container ← تتحكم فيها سلة مباشرة
   نضيف هنا فقط:
   1. ستايل الهيرو الشفاف (body.index فقط)
   2. ستايل مكوناتنا المخصصة .lv-*
   ============================================================ #}

{% block styles %}
<style>

/* ─── الهيرو الشفاف على الصفحة الرئيسية فقط ─────────────── */
{% if theme.settings.show_transparent_header %}

/* نخفي الشريط الداكن العلوي في الصفحة الرئيسية */
body.index .top-navbar {
    display: none !important;
}

/* نجعل الهيرو يبدأ من السطر صفر (الهدر يطفو فوقه) */
body.index .store-header {
    position: fixed !important;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 100;
    background: transparent !important;
}

/* الهدر شفاف قبل التمرير */
body.index:not(.lv-scrolled) .main-nav-container .inner,
body.index:not(.lv-scrolled) #mainnav {
    background: transparent !important;
    box-shadow: none !important;
}

/* نص وأيقونات الهدر باللون الأبيض على الهيرو */
body.index:not(.lv-scrolled) .navbar-brand img {
    filter: brightness(0) invert(1);
}
body.index:not(.lv-scrolled) .header-btn__icon {
    color: #fff !important;
    border-color: rgba(255,255,255,0.3) !important;
}
body.index:not(.lv-scrolled) .mburger b {
    background: #fff !important;
}
body.index:not(.lv-scrolled) custom-main-menu {
    color: #fff !important;
}
body.index:not(.lv-scrolled) .main-menu > li > a {
    color: #fff !important;
}

/* بعد التمرير → الهدر يصبح أبيض بانتقال ناعم */
body.index .main-nav-container .inner {
    transition: background 0.35s ease, box-shadow 0.35s ease;
}
body.index.lv-scrolled .main-nav-container .inner,
body.index.lv-scrolled #mainnav {
    background: #fff !important;
    box-shadow: 0 2px 20px rgba(0,0,0,0.08) !important;
}
body.index.lv-scrolled .navbar-brand img {
    filter: none;
}
body.index.lv-scrolled .header-btn__icon {
    color: inherit !important;
    border-color: inherit !important;
}
body.index.lv-scrolled custom-main-menu {
    color: inherit !important;
}

{% endif %}

/* ─── بوابة الدخول Gateway ────────────────────────────────── */
.lv-gateway {
    position: fixed; inset: 0; z-index: 99999;
}
.lv-gw-panel {
    position: absolute; top: 0; bottom: 0; width: 50%;
    background: #0e0d0c;
    transition: transform 1.1s cubic-bezier(0.77, 0, 0.18, 1);
}
.lv-gw-panel--l { left: 0; }
.lv-gw-panel--r { right: 0; }
.lv-gw-center {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 2; pointer-events: none;
}
.lv-gw-line {
    height: 1px; background: #C9A84C; width: 0;
    margin-bottom: 40px;
    animation: lvLine 1.2s ease 0.3s forwards;
}
.lv-gw-line-b {
    height: 1px; background: #C9A84C; width: 0;
    margin-top: 40px;
    animation: lvLine 1.2s ease 0.3s forwards;
}
@keyframes lvLine { to { width: 180px; } }
.lv-gw-logo {
    max-width: 200px; max-height: 90px; object-fit: contain;
    opacity: 0; animation: lvFade 0.9s ease 0.8s forwards;
}
.lv-gw-name {
    color: #fff; font-size: 1.8rem; font-weight: 200;
    letter-spacing: 10px; text-transform: uppercase;
    opacity: 0; animation: lvFade 0.9s ease 0.8s forwards;
}
.lv-gw-sub {
    color: #C9A84C; font-size: 10px; letter-spacing: 5px;
    text-transform: uppercase; margin-top: 14px;
    opacity: 0; animation: lvFade 0.9s ease 1.1s forwards;
}
.lv-gw-btn {
    position: absolute; bottom: 48px;
    left: 50%; transform: translateX(-50%);
    color: rgba(255,255,255,0.6); font-size: 11px;
    letter-spacing: 4px; text-transform: uppercase;
    opacity: 0; animation: lvFade 0.8s ease 1.8s forwards;
    border: 1px solid rgba(255,255,255,0.25);
    background: transparent; cursor: pointer;
    z-index: 3; padding: 12px 28px; pointer-events: all;
}
@keyframes lvFade { to { opacity: 1; } }
.lv-gateway.is-open .lv-gw-panel--l { transform: translateX(-100%); }
.lv-gateway.is-open .lv-gw-panel--r { transform: translateX(100%); }
.lv-gateway.is-gone {
    opacity: 0; visibility: hidden;
    transition: opacity 0.5s ease 0.8s, visibility 0s ease 1.4s;
}

/* شاشة بداية بسيطة */
.lv-splash {
    position: fixed; inset: 0; z-index: 99999;
    display: flex; align-items: center; justify-content: center;
    background: #fff;
    animation: lvSplash 0.7s ease 2.6s forwards;
}
@keyframes lvSplash { to { opacity: 0; visibility: hidden; } }

/* ─── قسم الهيرو ──────────────────────────────────────────── */
.lv-hero {
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
}
.lv-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
}
.lv-hero__video {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
}
.lv-hero__overlay { position: absolute; inset: 0; }
.lv-hero__content {
    position: relative; z-index: 2;
    text-align: center; padding: 0 24px;
}
.lv-hero__badge {
    display: block; color: #C9A84C;
    letter-spacing: 5px; font-size: 11px;
    text-transform: uppercase; margin: 0 0 16px;
}
.lv-hero__title {
    color: #fff;
    font-size: clamp(2rem, 6vw, 4.5rem);
    font-weight: 200; margin: 0 0 16px;
    line-height: 1.05; letter-spacing: 2px;
}
.lv-hero__sub {
    display: block; color: rgba(255,255,255,0.82);
    font-size: 1rem; margin: 0 0 36px;
}
.lv-hero__btn {
    display: inline-block; padding: 14px 48px;
    background: transparent; color: #fff;
    border: 1px solid rgba(255,255,255,0.8);
    text-decoration: none; font-size: 13px;
    letter-spacing: 3px; text-transform: uppercase;
    transition: all 0.3s;
}
.lv-hero__btn:hover { background: #fff; color: #1a1a1a; }
.lv-hero__scroll {
    position: absolute; bottom: 32px;
    left: 50%; transform: translateX(-50%); z-index: 3;
}
.lv-hero__scroll span {
    display: block; width: 1px; height: 52px;
    background: rgba(255,255,255,0.45);
    animation: lvScroll 1.8s ease infinite;
}
@keyframes lvScroll {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(0.3); opacity: 0.3; }
}

/* سلايدر الهيرو */
.lv-slider { position: absolute; inset: 0; }
.lv-slide {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity 1s ease;
}
.lv-slide.active { opacity: 1; }
.lv-slide img { width: 100%; height: 100%; object-fit: cover; }
.lv-dots {
    position: absolute; bottom: 28px;
    left: 50%; transform: translateX(-50%);
    display: flex; gap: 8px; z-index: 3;
}
.lv-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: rgba(255,255,255,0.4);
    border: none; cursor: pointer; padding: 0;
    transition: background 0.3s;
}
.lv-dot.active { background: #fff; }

/* ─── القسم العدلي / قصة الماركة ─────────────────────────── */
.lv-editorial {
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: stretch; min-height: 560px;
}
.lv-editorial__img { overflow: hidden; }
.lv-editorial__img img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
}
.lv-editorial__body {
    background: #f9f7f4;
    display: flex; flex-direction: column;
    justify-content: center; padding: 80px 64px;
}
.lv-editorial__badge {
    display: block; color: #C9A84C;
    letter-spacing: 5px; font-size: 11px;
    text-transform: uppercase; margin: 0 0 20px;
}
.lv-editorial__title {
    font-size: 2.2rem; font-weight: 200;
    color: #1a1a1a; margin: 0 0 24px; line-height: 1.2;
}
.lv-editorial__text {
    color: #666; line-height: 1.9;
    margin: 0 0 40px; font-size: 15px;
}
.lv-editorial__btn {
    display: inline-block; padding: 12px 36px;
    border: 1px solid #1a1a1a; color: #1a1a1a;
    text-decoration: none; font-size: 12px;
    letter-spacing: 2px; text-transform: uppercase;
    transition: all 0.3s; align-self: flex-start;
}
.lv-editorial__btn:hover { background: #1a1a1a; color: #fff; }

/* ─── زر واتساب ───────────────────────────────────────────── */
.lv-wa {
    position: fixed; bottom: 28px; z-index: 9999;
    width: 54px; height: 54px; background: #25D366;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(37,211,102,0.4);
    transition: transform 0.2s;
}
.lv-wa:hover { transform: scale(1.1); }
.lv-wa-l { left: 26px; }
.lv-wa-r { right: 26px; }

/* ─── زر للأعلى ───────────────────────────────────────────── */
#lv-top {
    position: fixed; bottom: 28px; right: 26px;
    z-index: 9998; width: 44px; height: 44px;
    background: #1a1a1a; color: #fff;
    border: none; cursor: pointer; border-radius: 50%;
    display: none; align-items: center; justify-content: center;
    font-size: 18px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    transition: background 0.2s;
}
#lv-top:hover { background: #C9A84C; }

/* ─── استجابة للجوال ──────────────────────────────────────── */
@media (max-width: 1024px) {
    .lv-editorial { grid-template-columns: 1fr; min-height: auto; }
    .lv-editorial__img { min-height: 360px; }
    .lv-editorial__body { padding: 56px 40px; }
}
@media (max-width: 768px) {
    .lv-editorial__body { padding: 36px 20px; }
    .lv-editorial__title { font-size: 1.8rem; }
    .lv-wa { width: 48px; height: 48px; }
}

</style>
{% endblock %}

{# ============================================================
   CONTENT — محتوى الصفحة الرئيسية
   ============================================================ #}

{% block content %}

{# ── شاشة البداية ──────────────────────────────────────────── #}
{% if theme.settings.show_splash %}
    {% if theme.settings.splash_type == 'logo' %}
        <div class="lv-splash">
            {% if theme.settings.splash_image %}
                <img src="{{ theme.settings.splash_image }}" alt="{{ store.name }}"
                     style="max-width:220px;max-height:120px;object-fit:contain">
            {% elseif store.logo %}
                <img src="{{ store.logo }}" alt="{{ store.name }}"
                     style="max-width:220px;max-height:120px;object-fit:contain">
            {% else %}
                <span style="font-size:1.8rem;font-weight:200;letter-spacing:10px;color:#1a1a1a">{{ store.name }}</span>
            {% endif %}
        </div>
    {% else %}
        <div class="lv-gateway" id="lv-gw">
            <div class="lv-gw-panel lv-gw-panel--l"></div>
            <div class="lv-gw-panel lv-gw-panel--r"></div>
            <div class="lv-gw-center">
                <div class="lv-gw-line"></div>
                {% if theme.settings.splash_image %}
                    <img src="{{ theme.settings.splash_image }}" alt="{{ store.name }}" class="lv-gw-logo">
                {% elseif store.logo %}
                    <img src="{{ store.logo }}" alt="{{ store.name }}" class="lv-gw-logo">
                {% else %}
                    <div class="lv-gw-name">{{ store.name }}</div>
                {% endif %}
                {% if theme.settings.splash_text %}
                    <div class="lv-gw-sub">{{ theme.settings.splash_text }}</div>
                {% endif %}
                <div class="lv-gw-line-b"></div>
            </div>
            <button class="lv-gw-btn" id="lv-gw-btn">ENTER</button>
        </div>
    {% endif %}
{% endif %}

{# ── الهيرو الرئيسي ─────────────────────────────────────────── #}
<section class="lv-hero" style="height:100vh">

    {# --- خلفية الهيرو --- #}
    {% if theme.settings.hero_type == 'video' and theme.settings.hero_video_url %}
        <video autoplay muted loop playsinline class="lv-hero__video">
            <source src="{{ theme.settings.hero_video_url }}" type="video/mp4">
        </video>
    {% elseif theme.settings.hero_type == 'slider' %}
        <div class="lv-slider">
            {% if theme.settings.hero_image %}
                <div class="lv-slide active"><img src="{{ theme.settings.hero_image }}" alt="" loading="eager"></div>
            {% endif %}
            {% if theme.settings.hero_image_2 %}
                <div class="lv-slide"><img src="{{ theme.settings.hero_image_2 }}" alt="" loading="lazy"></div>
            {% endif %}
            {% if theme.settings.hero_image_3 %}
                <div class="lv-slide"><img src="{{ theme.settings.hero_image_3 }}" alt="" loading="lazy"></div>
            {% endif %}
        </div>
        <div class="lv-dots">
            {% if theme.settings.hero_image %}<button class="lv-dot active" aria-label="الشريحة 1"></button>{% endif %}
            {% if theme.settings.hero_image_2 %}<button class="lv-dot" aria-label="الشريحة 2"></button>{% endif %}
            {% if theme.settings.hero_image_3 %}<button class="lv-dot" aria-label="الشريحة 3"></button>{% endif %}
        </div>
    {% elseif theme.settings.hero_image %}
        <img src="{{ theme.settings.hero_image }}" alt="" class="lv-hero__bg" loading="eager">
    {% else %}
        <div class="lv-hero__bg" style="background:linear-gradient(160deg,#1a1a1a 0%,#2c2416 100%)"></div>
    {% endif %}

    {# --- طبقة التعتيم --- #}
    {% if theme.settings.hero_overlay_opacity == 'light' %}
        <div class="lv-hero__overlay" style="background:rgba(0,0,0,0.2)"></div>
    {% endif %}
    {% if theme.settings.hero_overlay_opacity == 'medium' %}
        <div class="lv-hero__overlay" style="background:rgba(0,0,0,0.45)"></div>
    {% endif %}
    {% if theme.settings.hero_overlay_opacity == 'dark' %}
        <div class="lv-hero__overlay" style="background:rgba(0,0,0,0.7)"></div>
    {% endif %}

    {# --- محتوى نصي على الهيرو --- #}
    {% if theme.settings.hero_title or theme.settings.hero_cta_text %}
    <div class="lv-hero__content">
        {% if theme.settings.hero_label %}
            <span class="lv-hero__badge">{{ theme.settings.hero_label }}</span>
        {% endif %}
        {% if theme.settings.hero_title %}
            <h1 class="lv-hero__title">{{ theme.settings.hero_title }}</h1>
        {% endif %}
        {% if theme.settings.hero_subtitle %}
            <span class="lv-hero__sub">{{ theme.settings.hero_subtitle }}</span>
        {% endif %}
        {% if theme.settings.hero_cta_text %}
            <a href="{{ theme.settings.hero_cta_link }}" class="lv-hero__btn">
                {{ theme.settings.hero_cta_text }}
            </a>
        {% endif %}
    </div>
    {% endif %}

    {# --- مؤشر التمرير --- #}
    {% if theme.settings.show_hero_scroll %}
        <div class="lv-hero__scroll"><span></span></div>
    {% endif %}

</section>

{# ── مكونات الصفحة الرئيسية (drag & drop من سلة) ─────────────── #}
{% component home %}

{# ── البنر الوسطي ─────────────────────────────────────────────── #}
{% if theme.settings.show_mid_banner and theme.settings.mid_banner_image %}
<section style="position:relative;overflow:hidden">
    <a href="{{ theme.settings.mid_banner_link }}">
        <img src="{{ theme.settings.mid_banner_image }}" alt=""
             style="width:100%;height:auto;display:block;max-height:620px;object-fit:cover">
    </a>
    {% if theme.settings.mid_banner_title %}
    <div style="position:absolute;inset:0;display:flex;align-items:center;
                justify-content:center;flex-direction:column;text-align:center;
                padding:24px;pointer-events:none">
        <h2 style="color:#fff;font-size:clamp(1.8rem,4vw,3.5rem);
                   font-weight:200;margin:0 0 28px;letter-spacing:2px">
            {{ theme.settings.mid_banner_title }}
        </h2>
        {% if theme.settings.mid_banner_cta_text %}
        <a href="{{ theme.settings.mid_banner_link }}"
           style="display:inline-block;padding:13px 44px;border:1px solid #fff;
                  color:#fff;text-decoration:none;font-size:12px;
                  letter-spacing:3px;pointer-events:all">
            {{ theme.settings.mid_banner_cta_text }}
        </a>
        {% endif %}
    </div>
    {% endif %}
</section>
{% endif %}

{# ── البنر الثاني ─────────────────────────────────────────────── #}
{% if theme.settings.show_banner2 and theme.settings.banner2_image %}
<a href="{{ theme.settings.banner2_link }}" style="display:block;overflow:hidden">
    <img src="{{ theme.settings.banner2_image }}" alt=""
         style="width:100%;display:block">
</a>
{% endif %}

{# ── قسم قصة الماركة Editorial ────────────────────────────────── #}
{% if theme.settings.show_editorial and theme.settings.editorial_image %}
<section class="lv-editorial">
    <div class="lv-editorial__img">
        <img src="{{ theme.settings.editorial_image }}" alt="{{ theme.settings.editorial_title }}">
    </div>
    <div class="lv-editorial__body">
        {% if theme.settings.editorial_label %}
            <span class="lv-editorial__badge">{{ theme.settings.editorial_label }}</span>
        {% endif %}
        {% if theme.settings.editorial_title %}
            <h2 class="lv-editorial__title">{{ theme.settings.editorial_title }}</h2>
        {% endif %}
        {% if theme.settings.editorial_text %}
            <p class="lv-editorial__text">{{ theme.settings.editorial_text }}</p>
        {% endif %}
        {% if theme.settings.editorial_cta_text %}
            <a href="{{ theme.settings.editorial_cta_link }}" class="lv-editorial__btn">
                {{ theme.settings.editorial_cta_text }}
            </a>
        {% endif %}
    </div>
</section>
{% endif %}

{# ── زر واتساب العائم ─────────────────────────────────────────── #}
{% if theme.settings.show_whatsapp_btn and theme.settings.whatsapp_number %}
<a href="https://wa.me/{{ theme.settings.whatsapp_number }}"
   target="_blank"
   rel="noopener noreferrer"
   class="lv-wa lv-wa-{{ theme.settings.whatsapp_position }}"
   aria-label="تواصل عبر واتساب">
    <svg width="26" height="26" fill="#fff" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-
