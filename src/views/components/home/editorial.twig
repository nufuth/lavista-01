{% if theme.settings.get('show_editorial', true) %}
    {% set editorial_image = theme.settings.get('editorial_image', '') %}
    <section class="lavista-editorial">
        <div class="container">
            <div class="lavista-editorial__grid">
                <div class="lavista-editorial__image-wrap">
                    {% if editorial_image %}
                        <img src="{{ editorial_image }}" alt="{{ theme.settings.get('editorial_title') }}" class="lavista-editorial__image" loading="lazy">
                    {% else %}
                        <div class="lavista-editorial__image-placeholder"><i class="sicon-perfume"></i></div>
                    {% endif %}
                </div>
                <div class="lavista-editorial__content">
                    <p class="lavista-editorial__label">{{ theme.settings.get('editorial_label', 'OUR STORY') }}</p>
                    <h2 class="lavista-editorial__title">{{ theme.settings.get('editorial_title', 'فن العطر الفاخر') }}</h2>
                    <p class="lavista-editorial__text">{{ theme.settings.get('editorial_text', 'نؤمن بأن العطر هو أكثر من مجرد رائحة.') }}</p>
                    <a href="{{ theme.settings.get('editorial_cta_link', '/page/about') }}" class="lavista-editorial__cta">
                        {{ theme.settings.get('editorial_cta_text', 'اعرف أكثر') }} <span>←</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endif %}
