{% set hero_type       = theme.settings.get('hero_type', 'image') %}
{% set hero_height     = theme.settings.get('hero_height', 'fullscreen') %}
{% set overlay_opacity = theme.settings.get('hero_overlay_opacity', 'medium') %}
{% set overlay_color   = theme.settings.get('hero_overlay_color', '#000000') %}
{% set content_pos     = theme.settings.get('hero_content_position', 'bottom-start') %}
{% set cta_style       = theme.settings.get('hero_cta_style', 'white') %}
{% set hero_image      = theme.settings.get('hero_image', '') %}
{% set hero_video      = theme.settings.get('hero_video_url', '') %}

{% set overlay_map = {'none':'0','light':'0.25','medium':'0.5','dark':'0.75'} %}
{% set overlay_val = overlay_map[overlay_opacity] | default('0.5') %}
{% set height_map = {'fullscreen':'100vh','large':'80vh','medium':'60vh'} %}
{% set hero_h = height_map[hero_height] | default('100vh') %}
{% set pos_class_map = {'bottom-start':'hero-content--bottom-start','bottom-center':'hero-content--bottom-center','bottom-end':'hero-content--bottom-end','center':'hero-content--center'} %}
{% set pos_class = pos_class_map[content_pos] | default('hero-content--bottom-start') %}

<section class="lavista-hero lavista-hero--{{ hero_height }}" style="height: {{ hero_h }}; min-height: 500px;">

    {% if hero_type == 'video' and hero_video %}
        <div class="lavista-hero__bg-video">
            {% if 'youtube.com' in hero_video or 'youtu.be' in hero_video %}
                {% set yt_id = hero_video | split('v=') | last | split('&') | first %}
                {% if 'youtu.be' in hero_video %}{% set yt_id = hero_video | split('youtu.be/') | last | split('?') | first %}{% endif %}
                <iframe src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_id }}&controls=0&showinfo=0&rel=0"
                        allow="autoplay; encrypted-media" allowfullscreen class="lavista-hero__youtube"></iframe>
            {% else %}
                <video autoplay muted loop playsinline class="lavista-hero__video">
                    <source src="{{ hero_video }}" type="video/mp4">
                </video>
            {% endif %}
        </div>
    {% else %}
        {% if hero_image %}
            <div class="lavista-hero__bg-image" style="background-image: url('{{ hero_image }}');"></div>
        {% else %}
            <div class="lavista-hero__bg-image lavista-hero__bg-image--placeholder"></div>
        {% endif %}
    {% endif %}

    {% if overlay_opacity != 'none' %}
        <div class="lavista-hero__overlay" style="background-color: {{ overlay_color }}; opacity: {{ overlay_val }};"></div>
    {% endif %}

    <div class="lavista-hero__content {{ pos_class }}">
        <div class="container">
            <div class="lavista-hero__inner">
                {% if theme.settings.get('hero_label') %}
                    <p class="lavista-hero__label">{{ theme.settings.get('hero_label', 'THE NEW COLLECTION') }}</p>
                {% endif %}
                <h1 class="lavista-hero__title">{{ theme.settings.get('hero_title', 'LAVISTA D27') }}</h1>
                {% if theme.settings.get('hero_subtitle') %}
                    <p class="lavista-hero__subtitle">{{ theme.settings.get('hero_subtitle', 'عطر أسطوري يُعيد تعريف الفخامة') }}</p>
                {% endif %}
                {% set cta_text = theme.settings.get('hero_cta_text', 'اكتشف الآن') %}
                {% set cta_link = theme.settings.get('hero_cta_link', '/products') %}
                {% if cta_text %}
                    <a href="{{ cta_link }}" class="lavista-hero__cta lavista-hero__cta--{{ cta_style }}">
                        {{ cta_text }} <span class="lavista-hero__cta-arrow">←</span>
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    {% if theme.settings.get('show_hero_scroll_indicator', true) %}
        <div class="lavista-hero__scroll"><span></span></div>
    {% endif %}
</section>
