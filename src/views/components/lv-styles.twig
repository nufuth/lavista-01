<style>
{% if not theme.settings.get('show_header_nav', true) %}
.header__nav,.header__center,.header-nav,.main-nav,.nav-links,.mega-menu,.header__menu,.categories-nav,.header__bottom{display:none!important}
{% endif %}
{% if not theme.settings.get('show_header_logo', true) %}
.header__logo,.logo,.site-logo,.header-logo,.header__brand{display:none!important}
{% endif %}
#lv-gateway{position:fixed;inset:0;z-index:99999;pointer-events:all}
.lv-gw-panel{position:absolute;top:0;bottom:0;width:50%;background:#0e0d0c;transition:transform 1.1s cubic-bezier(0.77,0,0.18,1)}
.lv-gw-panel--left{left:0}
.lv-gw-panel--right{right:0}
.lv-gw-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:2;pointer-events:none}
.lv-gw-line,.lv-gw-line-b{height:1px;background:#C9A84C;width:0;animation:gwLine 1.2s ease 0.3s forwards}
.lv-gw-line{margin-bottom:40px}
.lv-gw-line-b{margin-top:40px}
@keyframes gwLine{to{width:180px}}
.lv-gw-logo{max-width:200px;max-height:90px;object-fit:contain;opacity:0;animation:gwFade 0.9s ease 0.8s forwards}
.lv-gw-text{color:#fff;font-size:2rem;font-weight:200;letter-spacing:12px;text-transform:uppercase;opacity:0;animation:gwFade 0.9s ease 0.8s forwards}
.lv-gw-sub{color:#C9A84C;font-size:10px;letter-spacing:5px;text-transform:uppercase;margin-top:14px;opacity:0;animation:gwFade 0.9s ease 1.1s forwards}
.lv-gw-btn{position:absolute;bottom:48px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.45);font-size:10px;letter-spacing:4px;text-transform:uppercase;opacity:0;animation:gwFade 0.8s ease 1.8s forwards;border:none;background:transparent;cursor:pointer;z-index:3;padding:10px 24px}
@keyframes gwFade{to{opacity:1}}
#lv-gateway.lv-open .lv-gw-panel--left{transform:translateX(-100%)}
#lv-gateway.lv-open .lv-gw-panel--right{transform:translateX(100%)}
#lv-gateway.lv-gone{opacity:0;pointer-events:none;transition:opacity 0.4s ease 0.9s}
.lv-hero{position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.lv-hero__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.lv-hero__video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.lv-hero__overlay{position:absolute;inset:0}
.lv-hero__content{position:relative;z-index:2;text-align:center;padding:0 24px}
.lv-hero__label{color:#C9A84C;letter-spacing:5px;font-size:11px;text-transform:uppercase;margin:0 0 16px;display:block}
.lv-hero__title{color:#fff;font-size:clamp(2rem,6vw,5rem);font-weight:200;margin:0 0 16px;line-height:1.05;letter-spacing:2px}
.lv-hero__subtitle{color:rgba(255,255,255,0.82);font-size:1rem;margin:0 0 36px;display:block}
.lv-hero__btn{display:inline-block;padding:14px 48px;background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.8);text-decoration:none;font-size:13px;letter-spacing:3px;text-transform:uppercase;transition:all 0.3s}
.lv-hero__btn:hover{background:#fff;color:#1a1a1a}
.lv-slider{position:absolute;inset:0}
.lv-slider__item{position:absolute;inset:0;opacity:0;transition:opacity 1s ease}
.lv-slider__item.active{opacity:1}
.lv-slider__item img{width:100%;height:100%;object-fit:cover}
.lv-slider__dots{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:3}
.lv-slider__dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,0.4);border:none;cursor:pointer;padding:0;transition:background 0.3s}
.lv-slider__dot.active{background:#fff}
.lv-hero__scroll{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:3}
.lv-hero__scroll span{display:block;width:1px;height:52px;background:rgba(255,255,255,0.45);animation:scrollAnim 1.8s ease infinite}
@keyframes scrollAnim{0%,100%{transform:scaleY(1);opacity:1}50%{transform:scaleY(0.3);opacity:0.3}}
.lv-editorial{display:grid;grid-template-columns:1fr 1fr;align-items:stretch;min-height:560px}
.lv-editorial__img{overflow:hidden}
.lv-editorial__img img{width:100%;height:100%;object-fit:cover;display:block}
.lv-editorial__body{background:#f9f7f4;display:flex;flex-direction:column;justify-content:center;padding:80px 64px}
.lv-editorial__label{color:#C9A84C;letter-spacing:5px;font-size:11px;text-transform:uppercase;margin:0 0 20px}
.lv-editorial__title{font-size:2.2rem;font-weight:200;color:#1a1a1a;margin:0 0 24px;line-height:1.2}
.lv-editorial__text{color:#666;line-height:1.9;margin:0 0 40px;font-size:15px}
.lv-editorial__btn{display:inline-block;padding:12px 36px;border:1px solid #1a1a1a;color:#1a1a1a;text-decoration:none;font-size:12px;letter-spacing:2px;text-transform:uppercase;transition:all 0.3s}
.lv-editorial__btn:hover{background:#1a1a1a;color:#fff}
.lv-wa{position:fixed;bottom:28px;z-index:9999;width:54px;height:54px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.4);transition:transform 0.2s}
.lv-wa:hover{transform:scale(1.1)}
.lv-wa--left{left:26px}
.lv-wa--right{right:26px}
#lv-top-btn{position:fixed;bottom:28px;right:26px;z-index:9998;width:44px;height:44px;background:#1a1a1a;color:#fff;border:none;cursor:pointer;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:18px;box-shadow:0 4px 16px rgba(0,0,0,0.2);transition:background 0.2s}
#lv-top-btn:hover{background:#C9A84C}
@media(max-width:1024px){.lv-editorial{grid-template-columns:1fr;min-height:auto}.lv-editorial__img{min-height:380px}.lv-editorial__body{padding:56px 40px}}
@media(max-width:768px){.lv-editorial__body{padding:40px 24px}.lv-editorial__title{font-size:1.8rem}.lv-wa{width:48px;height:48px}.lv-wa--left{left:18px}.lv-wa--right{right:18px}#lv-top-btn{bottom:20px;right:18px}}
</style>
