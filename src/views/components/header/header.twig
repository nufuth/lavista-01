{% set logo_size = theme.settings.get('logo_size', 'medium') %}
{% set logo_height_map = { 'small': '40px', 'medium': '70px', 'large': '100px', 'xlarge': '130px' } %}
{% set logo_h = logo_height_map[logo_size] | default('70px') %}
{% set is_transparent = theme.settings.get('header_transparent', true) %}
{% set is_sticky = theme.settings.get('header_is_sticky', true) %}
{% set header_bg = theme.settings.get('header_bg_color', '#ffffff') %}

<header class="lavista-header{% if is_sticky %} lavista-header--sticky{% endif %}{% if is_transparent %} lavista-header--transparent{% endif %}"
        id="lavista-header"
        style="--header-bg: {{ header_bg }};">

    {% if theme.settings.get('show_announcement', true) %}
        {% set ann_bg   = theme.settings.get('announcement_bg_color', '#1a1a1a') %}
        {% set ann_text = theme.settings.get('announcement_text_color', '#ffffff') %}
        {% set ann_link = theme.settings.get('announcement_link', '') %}
        <div class="announcement-bar" style="background: {{ ann_bg }}; color: {{ ann_text }};">
            <div class="container">
                {% if ann_link %}
                    <a href="{{ ann_link }}" class="announcement-bar__text" style="color: {{ ann_text }};">
                        {{ theme.settings.get('announcement_text', 'شحن مجاني للطلبات فوق 200 ريال') }}
                    </a>
                {% else %}
                    <p class="announcement-bar__text">
                        {{ theme.settings.get('announcement_text', 'شحن مجاني للطلبات فوق 200 ريال') }}
                    </p>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <div class="header-top">
        <div class="container header-top__inner">
            <div class="header-top__actions header-top__actions--start">
                <salla-user class="header-icon-btn" icon-only></salla-user>
                {% if theme.settings.get('show_search_icon', true) %}
                    <button class="header-icon-btn" onclick="salla.event.dispatch('search::open')" aria-label="بحث">
                        <i class="sicon-search"></i>
                    </button>
                {% endif %}
            </div>
            <div class="header-logo" style="--logo-h: {{ logo_h }};">
                <a href="{{ link('/') }}" class="header-logo__link" aria-label="{{ store.name }}">
                    {% if store.logo %}
                        <img src="{{ store.logo }}" alt="{{ store.name }}" class="header-logo__img" style="max-height: {{ logo_h }};" loading="eager">
                    {% else %}
                        <div class="header-logo__text">
                            <span class="header-logo__name">LA VISTA</span>
                            <span class="header-logo__sub">PERFUMES</span>
                        </div>
                    {% endif %}
                </a>
            </div>
            <div class="header-top__actions header-top__actions--end">
                {% if theme.settings.get('show_wishlist_icon', true) %}
                    <a href="{{ link('wishlist') }}" class="header-icon-btn" aria-label="المفضلة">
                        <i class="sicon-heart"></i>
                    </a>
                {% endif %}
                <salla-cart-summary class="header-icon-btn header-cart-btn"></salla-cart-summary>
            </div>
        </div>
    </div>

    <nav class="main-nav" id="mainnav" role="navigation">
        <div class="container">
            <div class="main-nav__inner">
                <button class="mobile-burger lg:hidden" onclick="salla.event.dispatch('menu::open')" aria-label="القائمة">
                    <i class="sicon-menu"></i>
                </button>
                <salla-menu source="main" class="main-nav__menu hidden lg:flex"></salla-menu>
                {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                    <salla-localization-modal show-trigger class="main-nav__locale"></salla-localization-modal>
                {% endif %}
            </div>
        </div>
    </nav>

    <salla-side-menu>
        <salla-menu source="main"></salla-menu>
    </salla-side-menu>
    <salla-search></salla-search>
</header>
