<!DOCTYPE html>
<html lang="{{ language.code }}" dir="{{ theme.is_rtl ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ theme.settings.set('placeholder', 'images/placeholder.png') }}
    <script defer data-cfasync="false" crossorigin="anonymous" src="{{ 'product-card.js'|asset }}"></script>
    <script defer src="{{ 'main-menu.js'|asset }}"></script>
    {% if theme.settings.get('enable_add_product_toast', true) %}
        <script defer src="{{ 'add-product-toast.js'|asset }}"></script>
    {% endif %}
    {% block head_scripts %}{% endblock %}
    <script data-cfasync="false">
        window.header_is_sticky      = "{{ theme.settings.get('header_is_sticky', true) }}"
        window.header_transparent    = "{{ theme.settings.get('header_transparent', true) }}"
        window.imageZoom             = "{{ theme.settings.get('imageZoom', true) }}"
        window.can_access_wallet     = {{ user.can_access_wallet | json_encode }}
        window.enable_add_product_toast = "{{ theme.settings.get('enable_add_product_toast', true) }}"
        window.show_back_to_top      = "{{ theme.settings.get('show_back_to_top', true) }}"
    </script>
    {% hook 'head:start' %}
    {% hook head %}
    {% block styles %}{% endblock %}
    <link rel="stylesheet" href="{{ 'app.css' | asset }}">
    <link rel="stylesheet" href="{{ theme.font.path|cdn }}"/>
    <link rel="stylesheet" href="{{ 'fonts/sallaicons.css'|cdn }}"/>
    {% set chosen_font = theme.settings.get('font_family', 'Tajawal') %}
    {% set font_size   = theme.settings.get('font_size', 'medium') %}
    <style>
        :root {
            --font-main: '{{ chosen_font }}', '{{ theme.font.name }}', 'DINNextLTArabic', -apple-system, sans-serif;
            --color-primary:         {{ theme.color.primary }};
            --color-primary-dark:    {{ theme.color.darker(0.15) }};
            --color-primary-light:   {{ theme.color.lighter(0.15) }};
            --color-primary-reverse: {{ theme.color.reverse_text }};
            --lavista-gold:   {{ theme.settings.get('accent_color', '#C9A84C') }};
            --lavista-dark:   {{ theme.settings.get('primary_color', '#1a1a1a') }};
            --lavista-cream:  {{ theme.settings.get('bg_color', '#f9f7f4') }};
        }
        body { font-family: var(--font-main); }
    </style>
    {% hook 'head:end' %}
</head>
<body id="app"
      class="lavista-theme overflow-x-hidden
             {{ theme.settings.get('footer_is_dark', true) ? ' footer-is-dark' : ' footer-is-light' }}
             {{ theme.settings.get('topnav_is_dark', true) ? ' topnav-is-dark' : '' }}"
      data-font-size="{{ font_size }}">
<noscript>يرجى تفعيل JavaScript لتشغيل هذا الموقع.</noscript>
<div class="app-inner flex flex-col min-h-full">
    {% hook 'body:start' %}
    {% component 'header.header' %}
    <main id="main-content" role="main" {% if theme.settings.get('header_transparent', true) %}class="has-transparent-header"{% endif %}>
        {% block content %}{% endblock %}
    </main>
    {% component 'footer.footer' %}
</div>
{% hook 'body:end' %}
{% if theme.settings.get('enable_add_product_toast', true) %}
    <salla-add-product-toast></salla-add-product-toast>
{% endif %}
<salla-offer-modal></salla-offer-modal>
<salla-login-modal></salla-login-modal>
{% if store.scope %}
    <salla-scopes selection="{{ store.scope.display_as == 'popup' ? 'mandatory' : 'optional' }}"></salla-scopes>
{% endif %}
<script defer crossorigin="anonymous" src="{{ 'app.js' | asset }}"></script>
{% block scripts %}{% endblock %}
</body>
</html>
